    case application_method:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        screen_switch = advanced_settings;

        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        uint16_value = cursor - anti_vibration;  // anakarta register hazırlandı yazmak için

        modbus_master.read_or_write(1, WRITE_MULTI, 0x0244, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        tick_location = uint16_value + 1;

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {

        modbus_master.read_or_write(1, READ_HOLDING, 0x0244, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        tick_location = uint16_value + 1;
      }

      bar_select(basic_settings_icon, 228, 120, middle_aligned, true, 229, 126, 230, 231, anti_vibration, test);

      break;

    case measure_mode:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = advanced_settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(advanced_setting_icon, 232, 130, left_aligned, false, 233, 86, pressure_, temperature_);

      break;

    case pressure_:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        screen_switch = measure_mode;

        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        if (cursor == auto_) {
          if (uint16_value == 0) uint16_value = 16;
          else if (uint16_value == 1) uint16_value = 17;
          tick_location = 1;
        } else if (cursor == manual) {
          if (uint16_value == 16) uint16_value = 0;
          else if (uint16_value == 17) uint16_value = 1;
          tick_location = 2;
        }

        modbus_master.read_or_write(1, WRITE_MULTI, 0x0245, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        modbus_master.read_or_write(1, READ_HOLDING, 0x0245, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre
        if (uint16_value == 16 || uint16_value == 17) tick_location = 1;
        else if (uint16_value == 0 || uint16_value == 1) tick_location = 2;
      }

      bar_select(basic_settings_icon, 233, 140, middle_aligned, true, 246, 247, auto_, manual);


      break;

    case temperature_:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        screen_switch = measure_mode;

        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        if (cursor == auto_) {
          if (uint16_value == 16) uint16_value = 17;
          else if (uint16_value == 0) uint16_value = 1;
          tick_location = 1;
        } else if (cursor == manual) {
          if (uint16_value == 1) uint16_value = 0;
          else if (uint16_value == 17) uint16_value = 16;
          tick_location = 2;
        }

        modbus_master.read_or_write(1, WRITE_MULTI, 0x0245, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        modbus_master.read_or_write(1, READ_HOLDING, 0x0245, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre
        if (uint16_value == 1 || uint16_value == 17) tick_location = 1;
        else if (uint16_value == 0 || uint16_value == 16) tick_location = 2;
      }

      bar_select(basic_settings_icon, 86, 140, middle_aligned, true, 246, 247, auto_, manual);


      break;

