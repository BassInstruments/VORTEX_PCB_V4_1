// DEĞİŞKENLER
// Ayarlanabilir
uint8_t slave_ID = 1;
uint16_t baud_rate_value = 9600;
uint16_t parity_bit_value = 0;  // None = 0, Odd = 1, Even = 2
uint16_t stop_bit_value = 1;
uint16_t main_password = 0000;
const uint16_t master_password = 1863; // master şifre
uint8_t theme_color = dark_theme;
float screen_refresh_time_value = 1;  // ekran değerleri yenileme süresi

// Modbus slave değişkenleri
const uint8_t holding_registers_quantity = 14;
uint16_t holdingRegisters[holding_registers_quantity];  // Toplamda 6 adet 16-bit register (3 float, 1 int32, 2 uint32)

float flow;       // anlık akış
float flow_rate;  // akış hızı
float mA_out;     // out mA çıkış
float total_differential; // total fark
float temperature; // total ileri yön
float pressure; // total geri yön
float density_modbus; 

uint16_t flow_address = 0; 
uint16_t flow_rate_address = 2;
uint16_t mA_out_address = 4;
uint16_t total_differential_address = 6;
uint16_t temperature_address = 8;
uint16_t pressure_address = 10;
uint16_t density_address = 12;

uint16_t register_adress = 10000; // slave registarlara yazma işlemi olduysa o register ın adresini alır

// Cihaz parametleri
uint16_t language = Turkish;
// uint16_t language = English;
uint16_t flow_unit_value = 0, total_unit_value = 0;
uint16_t flow_direction_value = 0;
uint16_t density_unit_value = 0;
uint16_t analog_out_1_type = 0, analog_out_2_type = _ma_4_20, analog_out_3_type = v_0_10;
uint16_t measure_mode_value = 0;
float flow_zero_value = 0;

// Fonksiyonlar arası kullanılan değişkenler
uint8_t screen_switch = main_screen;   // başlangıç ekranını seç
uint8_t previous_screen_switch = 0;
uint8_t button_state = 0, idle = 0;
bool page_change = true;                        // sayfa numarası değişimi takibi için
unsigned long last_time = 0, current_time = 0;  // zamanlama değişkenleri
float time_for_main_sreens = 0, conductivity_temperature_second = 0;
uint8_t half_second = 0, second_for_outputs_set = 0, second_for_menu = 0;  // zamanlama değişkenleri
uint8_t password_validity_time = 150;                                      // zamanlama değişkenleri
int16_t cursor = 0, previous_cursor = 0;                                   // menu ekranı setting seçim değişkeni
bool sign_digit, sign_state, decimal_state;                                // Sayı giriş ekranı "+" "- " işaret durumu değişkeni
int8_t number[8];
int8_t digit, previous_digit;          // Sayı giriş ekranı kırmızı çizgi konumu
float read_or_write_number;            // Veri giriş ekranı sayısı
uint8_t time_after_communication = 8;  // modbus haberleşmesi ardından bir sonraki haberleşme ile çakışma olmaması için beklenecek süre ms cinsinden
float previous_flow_rate = 0;          // Automatic zero için bir önceki akış hızı
char flow_buffer[10], total_buffer[10];
uint16_t previous_flow_unit;
float percentage;                                                                                  // anlık akış yüzdesi
uint16_t upper_limit_VDC = 201, lower_limit_VDC = 2, upper_limit_mA = 2567, lower_limit_mA = 482;  // kalibrasyon değerleri
uint16_t calibration_value;                                                                        // kalibrasyon ekranındaki değişen sayı
uint16_t digital_out_selection;
uint8_t page_number;
bool opening_page = true;                          // sayfa ilk görüntüsünü bir kez basma için onay değişkeni
bool left_aligned = true, middle_aligned = false;  // bar stil seçimi
uint16_t tick_location, previous_tick_location=0;
uint16_t alarm_state = 0, previous_alarm_state = 0, D_out_2_alarm_state = 4, D_out_3_alarm_state = 8;  // Alarm durumu registerı
float volatile_float;
uint16_t volatile_uint16;
float conductivity_k_factor_value = 1;
float flow_range_value;

// wifi parametleri
const char* ssid = "bass";              // Wi-Fi SSID
const char* password = "12345678";      // Wi-Fi Password
const char* firmwareUrl = "https://raw.githubusercontent.com/BassInstruments/VORTEX_PCB_V2/main/VORTEX_PCB_V2.ino.bin";

// NESNELER
ModbusMaster modbus_master;  // Modbus master nesnesini olustur
ModbusRTUSlave modbus_slave(Serial, DE_RE_PIN_1);  // Modbus slave nesnesini oluştur
TFT_eSPI tft = TFT_eSPI();  // TFT nesnesini olustur
MCP4725 MCP(MPC_DAC_ADDRESS); // Akım çıkışı için MCP nesnesi oluştur

// BUTON KESMESİ FONKSİYON PROTOTİPLERİ
void IRAM_ATTR esc_button_interrupt();
void IRAM_ATTR up_button_interrupt();
void IRAM_ATTR down_button_interrupt();
void IRAM_ATTR enter_button_interrupt();
void IRAM_ATTR serial_interrupt();

void setup() {

  digitalWrite(LCD_BLK, LOW);

  // Modbus haberleşme pinlerini ayarla

  pinMode(DE_RE_PIN_1, OUTPUT);
  pinMode(DE_RE_PIN_2, OUTPUT);

  pinMode(relay_pin, OUTPUT);
  pinMode(pulse_pin, OUTPUT);

  pinMode(LCD_BLK, OUTPUT);

  // Buton pinleri giriş ve pull up olarak ayarla
  pinMode(esc_button, INPUT_PULLDOWN);    // Dahili pull-up direncini etkinleştir
  pinMode(up_button, INPUT_PULLDOWN);     // Dahili pull-up direncini etkinleştir
  pinMode(down_button, INPUT_PULLDOWN);   // Dahili pull-up direncini etkinleştir
  pinMode(enter_button, INPUT_PULLDOWN);  // Dahili pull-up direncini etkinleştir

  // baslangicta modbus dinleme modunda
  digitalWrite(DE_RE_PIN_1, LOW);
  digitalWrite(DE_RE_PIN_2, LOW);

  // baslangicta cikislar düsük modda
  digitalWrite(relay_pin, LOW);
  digitalWrite(pulse_pin, LOW);

  digitalWrite(LCD_BLK, LOW);


  // Buton kesme fonksiyonlarını butonlarla bağla
  attachInterrupt(esc_button, esc_button_interrupt, RISING);      //  kesme tanımla
  attachInterrupt(up_button, up_button_interrupt, RISING);        //  kesme tanımla
  attachInterrupt(down_button, down_button_interrupt, RISING);    //  kesme tanımla
  attachInterrupt(enter_button, enter_button_interrupt, RISING);  //  kesme tanımla

  // Serial (programlama uartı) kesmesi tanımlaması
  Serial.onReceive(serial_interrupt);

  EEPROM.begin(64);  // Eppromda 64 byte lık yer ayrıldı

  Wire.begin();  // I2C haberleşmesi için
  MCP.begin();   // Akım çıkışı için

  Serial2.begin(9600, SERIAL_8N1, MASTER_RX_PIN, MASTER_TX_PIN);
  modbus_master.begin(1, Serial2);  // Modbus master için slave ID = 1, UART 2 kullan

  tft.init();
  tft.setRotation(1);
  tft.setSwapBytes(true);

  delay(1000);
  digitalWrite(LCD_BLK, HIGH);
  beginning_logo_animation();

  // İlk çalışmada eepromu default değerlerle doldur
  if (EEPROM.readByte(eeprom_write_status_address) == 10) {  // eeprom a ilk değerlerin atamasının yapıldığı bilgisini taşıyan register adresine random atanan 697 değerini kontrol et.
    // ilk değer atamaları yapıldıysa değerleri kullanmak için değişkenlere ata
    slave_ID = EEPROM.readByte(slave_ID_eep_address);
    theme_color = EEPROM.readByte(theme_color_address);
    main_password = EEPROM.readUShort(main_password_address);
    baud_rate_value = EEPROM.readUShort(modbus_baud_rate_address);
    parity_bit_value = EEPROM.readUShort(modbus_parity_bit_address);
    stop_bit_value = EEPROM.readUShort(modbus_stop_bit_address);
    analog_out_2_type = EEPROM.readUShort(analog_out_2_type_address);
    analog_out_3_type = EEPROM.readUShort(analog_out_3_type_address);
    upper_limit_VDC = EEPROM.readUShort(upper_limit_VDC_address);
    lower_limit_VDC = EEPROM.readUShort(lower_limit_VDC_address);
    upper_limit_mA = EEPROM.readUShort(upper_limit_mA_address);
    lower_limit_mA = EEPROM.readUShort(lower_limit_mA_address);
    D_out_2_alarm_state = EEPROM.readUShort(D_out_2_alarm_state_address);
    D_out_3_alarm_state = EEPROM.readUShort(D_out_3_alarm_state_address);
    language = EEPROM.readUShort(language_address);
    conductivity_k_factor_value = EEPROM.readFloat(conductivity_k_factor_register_address);
    screen_refresh_time_value = EEPROM.readFloat(screen_refresh_time_value_address);
  } else {  // ilk değer atamaları yapılmadıysa ilk değerleri ata
    EEPROM.writeByte(slave_ID_eep_address, slave_ID);
    EEPROM.writeByte(theme_color_address, theme_color);
    EEPROM.writeByte(eeprom_write_status_address, 10);         // eeprom a ilk değerlerin atamasının yapıldığı bu değişkene örneğin 10 değerini kaydederek göster
    EEPROM.writeUShort(main_password_address, main_password);  // şifre değişiminde eeproma bu şekilde yazılacak
    EEPROM.writeUShort(modbus_baud_rate_address, 9600);
    EEPROM.writeUShort(modbus_parity_bit_address, parity_bit_value);
    EEPROM.writeUShort(modbus_stop_bit_address, stop_bit_value);
    EEPROM.writeUShort(analog_out_2_type_address, _ma_4_20);
    EEPROM.writeUShort(analog_out_3_type_address, v_0_10);
    EEPROM.writeUShort(upper_limit_VDC_address, upper_limit_VDC);
    EEPROM.writeUShort(lower_limit_VDC_address, lower_limit_VDC);
    EEPROM.writeUShort(upper_limit_mA_address, upper_limit_mA);
    EEPROM.writeUShort(lower_limit_mA_address, lower_limit_mA);
    EEPROM.writeUShort(D_out_2_alarm_state_address, D_out_2_alarm_state);
    EEPROM.writeUShort(D_out_3_alarm_state_address, D_out_3_alarm_state);
    EEPROM.writeUShort(language_address, language);
    EEPROM.writeFloat(conductivity_k_factor_register_address, conductivity_k_factor_value);
    EEPROM.writeFloat(screen_refresh_time_value_address, screen_refresh_time_value);

    EEPROM.commit();  // kaydet
  }

  // Stop bit ve parity bit ayarlarının hafızadan çekilmesi
  if (stop_bit_value == 1) {
    if (parity_bit_value == 0) {
      modbus_slave.begin(slave_ID, baud_rate_value, SERIAL_8N1, SLAVE_RX_PIN, SLAVE_TX_PIN);
    } else if (parity_bit_value == 1) {
      modbus_slave.begin(slave_ID, baud_rate_value, SERIAL_8O1, SLAVE_RX_PIN, SLAVE_TX_PIN);
    } else if (parity_bit_value == 2) {
      modbus_slave.begin(slave_ID, baud_rate_value, SERIAL_8E1, SLAVE_RX_PIN, SLAVE_TX_PIN);
    }
  } else if (stop_bit_value == 2) {
    if (parity_bit_value == 0) {
      modbus_slave.begin(slave_ID, baud_rate_value, SERIAL_8N2, SLAVE_RX_PIN, SLAVE_TX_PIN);
    } else if (parity_bit_value == 1) {
      modbus_slave.begin(slave_ID, baud_rate_value, SERIAL_8O2, SLAVE_RX_PIN, SLAVE_TX_PIN);
    } else if (parity_bit_value == 2) {
      modbus_slave.begin(slave_ID, baud_rate_value, SERIAL_8E2, SLAVE_RX_PIN, SLAVE_TX_PIN);
    }
  }

  modbus_slave.configureHoldingRegisters(holdingRegisters, holding_registers_quantity);  // Tek bir dizi içinde tüm holding registerlar

  // Callbacks allow us to configure the RS485 transceiver correctly
  modbus_master.preTransmission(preTransmission);
  modbus_master.postTransmission(postTransmission);

  // Ekranda gösterilecek mA biçimini registerdan oku
  modbus_master.read_or_write(1, READ_HOLDING, 0x0111, &analog_out_1_type);
  delay(time_after_communication);  // iki modbus haberleşmesi arası beklenecek min süre

}


void loop() {

  // Zamanlamayı çalıştır
  count_second();

  // Ekrana görüntü bas (içindeki modbus haberleşmelerinden kaynaklık olarak ms mertebesinden gecikmeleri mevcut)
  screen();

  modbus_slave_write();
}
/*******************************************************************************************************************************************/


/*******************************************************************************************************************************************/
// KONTROL FONKSİYONLARI
void screen() {  // bu fonksiyonu sürekli tekrarlar

  bool high_light = true, low_light = false;  // bar aydınlatma değişkenleri
  static uint16_t uint16_value;
  int16_t int16_value;
  int32_t int32_value;
  bool decimal_number = true, non_decimal_number = false;
  bool non_positive = true, positive = false;
  uint16_t language_state = 0;
  char calibration_value_buffer[6];
  static char sensor_frequency_buffer[10], density_buffer[10], pressure_buffer[10], temperature_buffer[10], ma_buffer[10], velocity_buffer[10];  // Sayıyı depolamak için yeterli büyüklükte bir dizi
  uint16_t percentage_bar;
  static uint8_t previous_half_second;
  static bool green_rectengular = true;
  static uint16_t alarm_Iout_enable;
  static uint16_t divider_value;
  static uint16_t decpoint = 0;  // anlık akış ekranda göstereceği ondalık sayısı
  static bool first_text = false;
  static bool alarm_animation = true;  // Alarm animasyonu için tersleme değişkeni
  static int8_t alarm_counter = 0;    // birden çok alarm gösterme değişkeni
  static float V;                      // out mA çıkış
  uint16_t dac_ma_value, dac_v_value;
  float percentage_V;
  float sensor_frequency;
  static uint8_t mass_or_volume, _mass = 0, _volume = 1;  // 0 mass, 1 volume
  static float high_alarm_value, low_alarm_value;

  const uint8_t degree[] PROGMEM = {
    0b001100,
    0b010010,
    0b010010,
    0b001100,
  };

  const uint16_t *icons_main[] = {
    basic_settings_icon,
    advanced_setting_icon,
    output_icon,
    communication_icon,
    display_icon,
    data_logging_icon,
    Information_icon
  };

  // Sayfa seçimi
  switch (screen_switch) {
    case main_screen:

      percentage_bar = percentage;
      if (percentage_bar < 0) percentage_bar = percentage_bar * -1;  // eksi ile barı dolduramayacağı için pozitif yapılıyor
      if (percentage_bar > 100) percentage_bar = 100;                // Bar ın taşmaması için limitle

      if (opening_page == true) {
        opening_page = false;
        page_change = true;         // sayfa değişimi olduğunu anlama için
        theme_color = white_theme;  // sil
        tft.fillScreen(TFT_WHITE);
        tft.setTextColor(TFT_BLACK, TFT_WHITE);

        tft.fillRect(0, 0, 320, 35, TFT_BLUEE);

        tft.drawLine(15, 112, 305, 112, TFT_BLUE);

        tft.setTextColor(TFT_WHITE, TFT_BLUEE);
        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        tft.drawString(ma_buffer, 85, 6, FONT4);
        tft.drawString(sensor_frequency_buffer, 270, 6, FONT4);
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama

        tft.setFreeFont(FSS9);
        tft.drawString("mA", 90, 11);
        tft.drawString("Hz", 275, 11);

        tft.setTextColor(TFT_NAVY, TFT_WHITE);
        tft.setTextDatum(TR_DATUM);                   // Sağa yaslı hizalama
        tft.drawString(flow_buffer, 223, 60, FONT6);  // Sayıyı ekrana yazdır
        draw_sigma(18, 128, TFT_NAVY);
        tft.drawString(total_buffer, 223, 128, FONT4);  // Sayıyı ekrana yazdır
        tft.setTextDatum(TL_DATUM);                     // Sağa yaslı hizalama
        tft.drawString("SW : 2.0", 35, 220, FONT2);
        tft.drawString("HW : 4.1", 107, 220, FONT2);
        tft.drawString("MSG :", 195, 220, FONT2);
        tft.drawString("NORMAL", 235, 220, FONT2);

        bar_graph_new(19, 166, percentage_bar, TFT_NAVY, TFT_CYAN, TFT_DARKGREY);

        // Akış birimi oku
        // Total unit ve flow unit oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x021C, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        // Akış birimi bas
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama

        // Flow Unit
        tft.setFreeFont(FSS12);
        if (uint16_value == 188) {
          tft.drawString("Nm3/h", 235, 77);
        } else if (uint16_value == 189) {
          tft.drawString("Nm3/m", 235, 77);
        } else if (uint16_value == 190) {
          tft.drawString("Nm3/s", 235, 77);
        } else if (uint16_value == 29) {
          tft.drawString("m3/d", 235, 77);
        } else if (uint16_value == 19) {
          tft.drawString("m3/h", 235, 77);
        } else if (uint16_value == 131) {
          tft.drawString("m3/m", 235, 77);
        } else if (uint16_value == 28) {
          tft.drawString("m3/s", 235, 77);
        } else if (uint16_value == 138) {
          tft.drawString("L/h", 235, 77);
        } else if (uint16_value == 17) {
          tft.drawString("L/m", 235, 77);
        } else if (uint16_value == 24) {
          tft.drawString("L/s", 235, 77);
        } else if (uint16_value == 185) {
          tft.drawString("Scf/h", 235, 77);
        } else if (uint16_value == 123) {
          tft.drawString("Scf/m", 235, 77);
        } else if (uint16_value == 186) {
          tft.drawString("Scf/s", 235, 77);
        } else if (uint16_value == 130) {
          tft.drawString("cf/h", 235, 77);
        } else if (uint16_value == 15) {
          tft.drawString("cf/m", 235, 77);
        } else if (uint16_value == 26) {
          tft.drawString("cf/s", 235, 77);
        } else if (uint16_value == 136) {
          tft.drawString("USG/h", 235, 79);
        } else if (uint16_value == 16) {
          tft.drawString("USG/m", 235, 79);
        } else if (uint16_value == 22) {
          tft.drawString("USG/s", 235, 79);
        } else if (uint16_value == 30) {
          tft.drawString("UKG/h", 235, 79);
        } else if (uint16_value == 18) {
          tft.drawString("UKG/m", 235, 79);
        } else if (uint16_value == 137) {
          tft.drawString("UKG/s", 235, 79);
        } else if (uint16_value == 135) {
          tft.drawString("bbl/d", 235, 77);
        } else if (uint16_value == 134) {
          tft.drawString("bbl/h", 235, 77);
        } else if (uint16_value == 79) {
          tft.drawString("ton/d", 235, 77);
        } else if (uint16_value == 78) {
          tft.drawString("ton/h", 235, 77);
        } else if (uint16_value == 77) {
          tft.drawString("ton/m", 235, 77);
        } else if (uint16_value == 76) {
          tft.drawString("kg/d", 235, 77);
        } else if (uint16_value == 75) {
          tft.drawString("kg/h", 235, 77);
        } else if (uint16_value == 74) {
          tft.drawString("kg/m", 235, 77);
        } else if (uint16_value == 73) {
          tft.drawString("kg/s", 235, 77);
        } else if (uint16_value == 72) {
          tft.drawString("g/h", 235, 77);
        } else if (uint16_value == 71) {
          tft.drawString("g/m", 235, 77);
        } else if (uint16_value == 70) {
          tft.drawString("g/s", 235, 77);
        } else if (uint16_value == 83) {
          tft.drawString("lb/d", 235, 77);
        } else if (uint16_value == 82) {
          tft.drawString("lb/h", 235, 77);
        }


        // Total Unit
        tft.setFreeFont(FSS9);
        if (uint16_value == 188 || uint16_value == 189 || uint16_value == 190) {
          tft.drawString("Nm3", 238, 133);
        } else if (uint16_value == 29 || uint16_value == 19 || uint16_value == 131 || uint16_value == 28) {
          tft.drawString("m3", 238, 133);
        } else if (uint16_value == 138 || uint16_value == 17 || uint16_value == 24) {
          tft.drawString("L", 238, 133);
        } else if (uint16_value == 185 || uint16_value == 123 || uint16_value == 186) {
          tft.drawString("Scf", 238, 133);
        } else if (uint16_value == 130 || uint16_value == 15 || uint16_value == 26) {
          tft.drawString("cf", 238, 133);
        } else if (uint16_value == 136 || uint16_value == 16 || uint16_value == 22) {
          tft.drawString("USG", 238, 134);
        } else if (uint16_value == 30 || uint16_value == 18 || uint16_value == 137) {
          tft.drawString("UKG", 238, 134);
        } else if (uint16_value == 135 || uint16_value == 134) {
          tft.drawString("bbl", 238, 133);
        } else if (uint16_value == 79 || uint16_value == 78 || uint16_value == 77) {
          tft.drawString("ton", 238, 133);
        } else if (uint16_value == 76 || uint16_value == 75 || uint16_value == 74 || uint16_value == 73) {
          tft.drawString("kg", 238, 133);
        } else if (uint16_value == 72 || uint16_value == 71 || uint16_value == 70) {
          tft.drawString("gram", 238, 133);
        } else if (uint16_value == 83 || uint16_value == 82) {
          tft.drawString("lb", 238, 133);
        }


        // Anlık akış için noktadan sonra kaç basamak olacağını oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x021F, &decpoint);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_master.read_or_write(1, READ_HOLDING, 0x0210, &high_alarm_value);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre
 
        modbus_master.read_or_write(1, READ_HOLDING, 0x0212, &low_alarm_value);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre

      }

      if (button_state == press_up) {
        button_state = idle;
        opening_page = true;

        screen_switch = second_screen;

        break;

      } else if (button_state == press_down) {
        button_state = idle;
        opening_page = true;

        screen_switch = second_screen;

        break;

      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;

        if (password_validity_time > 120) screen_switch = password_screen;  // password geçerlilik süresi devam ediyorsa şifre ekranını atla
        else {
          screen_switch = settings;  // devam etmiyorsa şifre ekranına git
        }
      }

      // Belirlenen sürede ekran verilerini güncelle
      if (time_for_main_sreens >= screen_refresh_time_value) {
        time_for_main_sreens = 0;  // saniye sıfırla

        static uint8_t previous_percentage;                                 // anlık akış yüzdesi
        static int32_t differantiel = 0;                                    // total ileri akış - total geri akış ham değer
        static float differantiel_float = 0;                                // total ileri akış - total geri akış float değeri
        uint8_t number_of_digit = 0;                                        // ekrana yazılacak bamasak sayısı
        static uint8_t previous_flow_digits, previous_differantiel_digits;  // ekrana yazılacak bamasak sayısı
        uint16_t pos_flow = 215, pos_differantiel = 250;                    // Anlık akış değeri başlangıç x koordinatı
        uint8_t character_counter = 0;                                      // bamasak hesaplama sayıcısı


        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Anlık akış değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0404, &flow);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, flow, flow_address);

        // Anlık akış değerine göre ekranda nokta kaydır
        if (decpoint == 1) {
          if (flow < 10 && flow > -10) decpoint = 1;
          else if (flow < 100 && flow > -100) decpoint = 1;
          else if (flow < 1000 && flow > -1000) decpoint = 1;
          else if (flow < 10000 && flow > -10000) decpoint = 1;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        } else if (decpoint == 2) {
          if (flow < 10 && flow > -10) decpoint = 2;
          else if (flow < 100 && flow > -100) decpoint = 2;
          else if (flow < 1000 && flow > -1000) decpoint = 2;
          else if (flow < 10000 && flow > -10000) decpoint = 2;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        } else if (decpoint == 3) {
          if (flow < 10 && flow > -10) decpoint = 3;
          else if (flow < 100 && flow > -100) decpoint = 3;
          else if (flow < 1000 && flow > -1000) decpoint = 3;
          else if (flow < 10000 && flow > -10000) decpoint = 2;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        } else if (decpoint == 4) {
          if (flow < 10 && flow > -10) decpoint = 4;
          else if (flow < 100 && flow > -100) decpoint = 4;
          else if (flow < 1000 && flow > -1000) decpoint = 3;
          else if (flow < 10000 && flow > -10000) decpoint = 2;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        }

        if (decpoint == 0) {
          sprintf(flow_buffer, "%.0f", flow);
        } else if (decpoint == 1) {
          sprintf(flow_buffer, "%.1f", flow);
        } else if (decpoint == 2) {
          sprintf(flow_buffer, "%.2f", flow);
        } else if (decpoint == 3) {
          sprintf(flow_buffer, "%.3f", flow);
        } else if (decpoint == 4) {
          sprintf(flow_buffer, "%.4f", flow);
        }

        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        tft.setTextColor(TFT_NAVY, TFT_WHITE);
        tft.setTextPadding(2000);
        tft.drawString(flow_buffer, 223, 60, FONT6);
        tft.setTextPadding(0);


        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama
        // if (theme_color == dark_theme) {
        //   tft.setTextColor(TFT_SILVER, TFT_BLACK);
        // } else {
        //   tft.setTextColor(TFT_BLACK, TFT_CREAM);
        // }

        // Alarm durumunu kontrol et ve ekrana bas
        modbus_master.read_or_write(1, READ_HOLDING, 0x0210, &high_alarm_value);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre

        modbus_master.read_or_write(1, READ_HOLDING, 0x0212, &low_alarm_value);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre

        if (flow > high_alarm_value) {
          alarm_state =  0b00000100;
        } else if (flow < low_alarm_value){
          alarm_state =  0b00001000;
        } else {
          alarm_state = 0;
        }

        // alarm durumunu ekrana bas
        if (screen_switch == main_screen || screen_switch == second_screen ) {
          if (alarm_state == 0) {
            if (previous_alarm_state != alarm_state || page_change == true) {
              tft.setTextColor(TFT_NAVY, TFT_WHITE);
              tft.drawString("NORMAL      ", 235, 220, FONT2);
              previous_alarm_state = alarm_state;             // önceki Alarm değerini koru
            }

          } else {  // Alarm yanıp sönme animasyonu için
            alarm_animation = !alarm_animation;

            if (theme_color == dark_theme) {
              if (alarm_animation) {
                tft.setTextColor(TFT_SILVER, TFT_BLACK);
              } else {
                tft.setTextColor(TFT_BLACK, TFT_SILVER);
              }
            } else {
              if (alarm_animation) {
                tft.setTextColor(TFT_WHITE, TFT_NAVY);
              } else {
                tft.setTextColor(TFT_NAVY, TFT_WHITE);
              }
            }

            bool alarm_counter_flag = false;
            while (alarm_counter < 6) {
              if ((alarm_state & (1 << 0)) && alarm_counter == 0) {  // alarm registerının 0. bitini kontrol et
                tft.drawString("ERR - 001", 235, 220, FONT2);         // Empt Pipe Alarm - Boş boru alarmı
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 1)) && alarm_counter == 1) {  // alarm registerının 1. bitini kontrol et
                tft.drawString("ERR - 002", 235, 220, FONT2);                // SYS Alarm (isimlendirilecek)
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 2)) && alarm_counter == 2) {  // alarm registerının 2. bitini kontrol et
                tft.drawString("ERR - 003", 235, 220, FONT2);              // High Flow Alarm - Yüksek akış alarmı
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 3)) && alarm_counter == 3) {  // alarm registerının 3. bitini kontrol et
                tft.drawString("ERR - 004", 235, 220, FONT2);                // Low Flow Alarm - Düşük akış alarmı
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 4)) && alarm_counter == 4) {  // alarm registerının 4. bitini kontrol et
                tft.drawString("ERR - 005", 235, 220, FONT2);                // Excitation Drive Alarm - DRV (isimlendirilecek)
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 5)) && alarm_counter == 5) {  // alarm registerının 5. bitini kontrol et
                tft.drawString("ERR - 006", 235, 220, FONT2);               // Eeprom Alarm (isimlendirilecek)
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if (alarm_counter_flag == false){
                alarm_counter = -1;
                alarm_counter_flag = true;
              }
              alarm_counter++;
            }

            if (alarm_counter >= 5) alarm_counter = 0;
            
            previous_alarm_state = alarm_state;  // önceki Alarm değerini koru
          }
          if (theme_color == dark_theme) {
            tft.setTextColor(TFT_WHITE, TFT_BLACK);
          } else {
            tft.setTextColor(TFT_NAVY, TFT_WHITE);
          }
        }

        // // Alarm durumuna göre dijital çıkışları organize et
        // if (alarm_state & (1 << 0)) {  // alarm registerının 0. bitini kontrol et
        //   // Empt Pipe Alarm - Boş boru alarmı
        //   if (D_out_2_alarm_state == 1) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 1) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // Empt Pipe Alarm - Boş boru alarmı
        //   if (D_out_2_alarm_state == 1) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 1) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (alarm_state & (1 << 1)) {  // alarm registerının 1. bitini kontrol et
        //   // SYS Alarm (isimlendirilecek)
        //   if (D_out_2_alarm_state == 2) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 2) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // SYS Alarm (isimlendirilecek)
        //   if (D_out_2_alarm_state == 2) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 2) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (alarm_state & (1 << 2)) {  // alarm registerının 2. bitini kontrol et
        //   // High Flow Alarm - Yüksek akış alarmı
        //   if (D_out_2_alarm_state == 4) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 4) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // High Flow Alarm - Yüksek akış alarmı
        //   if (D_out_2_alarm_state == 4) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 4) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (alarm_state & (1 << 3)) {  // alarm registerının 3. bitini kontrol et
        //   // Low Flow Alarm - Düşük akış alarmı
        //   if (D_out_2_alarm_state == 8) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 8) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // Low Flow Alarm - Düşük akış alarmı
        //   if (D_out_2_alarm_state == 8) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 8) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (D_out_2_alarm_state == 16) {
        //   if (flow < 0) {
        //     digitalWrite(pulse_pin, 1);
        //   } else {
        //     digitalWrite(pulse_pin, 0);
        //   }
        // }
        // if (D_out_3_alarm_state == 16) {
        //   if (flow < 0) {
        //     digitalWrite(relay_pin, 1);
        //   } else {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }

        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Toplam değeri bas
        modbus_master.read_or_write(1, READ_HOLDING, 0x040A, &total_differential);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, total_differential, total_differential_address);

        divider_value = 100;  // silinecek
        if (divider_value == 1) {
          sprintf(total_buffer, "%.0f", total_differential);
        } else if (divider_value == 10) {
          sprintf(total_buffer, "%.1f", total_differential);
        } else if (divider_value == 100) {
          sprintf(total_buffer, "%.2f", total_differential);
        } else if (divider_value == 1000) {
          sprintf(total_buffer, "%.3f", total_differential);
        }
        tft.setTextPadding(185);
        tft.drawString(total_buffer, 223, 128, FONT4);
        tft.setTextPadding(0);
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama


        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


        // mA değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0421, &mA_out);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, mA_out, mA_out_address);

        dac_ma_value = mapFloat(mA_out, 4, 21, lower_limit_mA, upper_limit_mA);  // 4 - 20 mA arasını dac için 0 - 255 e uyarla
        MCP.setValue(dac_ma_value);

        // mA değerini bas
        sprintf(ma_buffer, "%.2f", mA_out);

        tft.setFreeFont(FSS9);
        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        tft.setTextColor(TFT_WHITE, TFT_BLUEE);
        tft.setTextPadding(100);
        tft.drawString(ma_buffer, 85, 6, FONT4);
        tft.setTextPadding(0);
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Velocity değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0431, &flow_rate);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, flow_rate, flow_rate_address);

        // Frekans değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0408, &sensor_frequency);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        sprintf(sensor_frequency_buffer, "%.1f", sensor_frequency);

        // Akış hızı değerini bas

        // sprintf(velocity_buffer, "%8.3f", flow_rate);

        tft.setFreeFont(FSS9);
        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        tft.setTextPadding(100);
        tft.drawString(sensor_frequency_buffer, 270, 6, FONT4);
        tft.setTextPadding(0);
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Temperature değerini modbus çıkışı

        modbus_master.read_or_write(1, READ_HOLDING, 0x0425, &temperature);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, temperature, temperature_address);  // holding registera yaz

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Pressure değerini  modbus çıkışı
        modbus_master.read_or_write(1, READ_HOLDING, 0x0423, &pressure);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, pressure, pressure_address);  // holding registera yaz

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Density değeri  modbus çıkışı
        modbus_master.read_or_write(1, READ_HOLDING, 0x0427, &density_modbus);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, density_modbus, density_address);

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


        // yüzde değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0402, &percentage);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        percentage_bar = percentage;
        if (percentage_bar < 0) percentage_bar = percentage_bar * -1;  // eksi ile barı dolduramayacağı için pozitif yapılıyor
        if (percentage_bar > 100) percentage_bar = 100;                // Bar ın taşmaması için limitle

        // Bar ın kırpışmasını azaltmak için anlık akış yüzdesinde değişim yoksa tekrar bastırma
        if (previous_percentage != percentage_bar || page_change == true) {
          bar_graph_new(19, 166, percentage_bar, TFT_NAVY, TFT_CYAN, TFT_DARKGREY);
        }
        previous_percentage = percentage_bar;

        percentage_V = percentage;
        if (percentage_V > 100) percentage_V = 100;  // voltaj çıkışı 0 - 10v arasında olduğu için min max değerler sınırlandırılmıştır
        else if (percentage_V < -100) percentage_V = -100;
        // V değerini akışın yüzdesini baz alarak hesapla ve seçilen biçime göre çıkış ver
        if (analog_out_3_type == v_0_10) {                         // Akım çıkışı 4 - 20 mA seçildiyse
          if (percentage_V < 0) percentage_V = percentage_V * -1;  // Ters yöndeki akışı hesaplamalar için pozitife dönüştür
          if (percentage_V > 100) percentage_V = 100;              // 20.50 mA da sınırlaması için
          V = percentage_V * 10 / 100;
        } else if (analog_out_3_type == v_0_5_10) {  // Akım çıkışı 4 - 12 - 20 mA seçildiyse
          V = (percentage_V * 5 / 100) + 5;
        }

        dac_v_value = mapFloat(V, 0, 10, lower_limit_VDC, upper_limit_VDC);  // 0 - 10 VDC arasını dac için 0 - 255 e uyarla
        // dacWrite(DAC_2_PIN_V, dac_v_value);

        page_change = false;  // sayfa değişimi olmadığını göstermek için
      }

      break;

    case second_screen:

      percentage_bar = percentage;
      if (percentage_bar < 0) percentage_bar = percentage_bar * -1;  // eksi ile barı dolduramayacağı için pozitif yapılıyor
      if (percentage_bar > 100) percentage_bar = 100;                // Bar ın taşmaması için limitle


      if (opening_page == true) {
        opening_page = false;
        theme_color = white_theme;
        tft.fillScreen(TFT_WHITE);

        tft.fillRect(0, 0, 320, 35, TFT_BLUEE);
        tft.fillRect(0, 35, 320, 120, TFT_GRAYY);

        tft.drawLine(20, 92, 300, 92, TFT_BLUE);    // yan çizgi
        tft.drawLine(160, 45, 160, 145, TFT_BLUE);  // dik çizgi

        tft.setTextColor(TFT_WHITE, TFT_BLUEE);
        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        tft.drawString(ma_buffer, 85, 6, FONT4);
        tft.drawString(sensor_frequency_buffer, 270, 6, FONT4);
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama

        tft.setFreeFont(FSS9);
        tft.drawString("mA", 90, 11);
        tft.drawString("Hz", 275, 11);

        tft.setFreeFont(FSS18);
        tft.setTextColor(TFT_NAVY, TFT_WHITE);
        draw_sigma(18, 175, TFT_NAVY);
        tft.setTextDatum(TR_DATUM);              // Sağa yaslı hizalama
        tft.drawString(total_buffer, 241, 170);  // Sayıyı ekrana yazdır
        tft.setTextDatum(TL_DATUM);              // Sağa yaslı hizalama
        tft.drawString("SW : 2.0", 35, 220, FONT2);
        tft.drawString("HW : 4.1", 107, 220, FONT2);
        tft.drawString("MSG :", 195, 220, FONT2);
        tft.drawString("NORMAL", 235, 220, FONT2);
        tft.setFreeFont(FSS12);
        tft.setTextColor(TFT_NAVY, TFT_GRAYY);
        tft.setFreeFont(FSSB12);
        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama
        tft.drawString(flow_buffer, 95, 55);
        tft.setFreeFont(FSS12);
        tft.drawString(pressure_buffer, 255, 55);
        tft.drawString(density_buffer, 95, 109);
        tft.drawString(temperature_buffer, 255, 109);
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama
        tft.setFreeFont(FSS9);
        tft.drawString("kPa", 260, 60);
        tft.drawString("P", 170, 57);
        tft.drawString("kg/m3", 104, 114);
        tft.drawString("D", 5, 112);
        tft.drawString("C", 265, 114);
        tft.drawBitmap(260, 111, degree, 8, 4, TFT_NAVY);
        tft.drawString("T", 170, 111);

        // Akış birimi oku
        // Total unit ve flow unit oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x021C, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        // Akış birimi bas
        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama

        // Flow Unit
        if (uint16_value == 188) {
          tft.drawString("Nm3/h", 98, 65);
        } else if (uint16_value == 189) {
          tft.drawString("Nm3/m", 98, 65);
        } else if (uint16_value == 190) {
          tft.drawString("Nm3/s", 98, 65);
        } else if (uint16_value == 29) {
          tft.drawString("m3/d", 108, 65);
        } else if (uint16_value == 19) {
          tft.drawString("m3/h", 108, 60);
        } else if (uint16_value == 131) {
          tft.drawString("m3/m", 108, 65);
        } else if (uint16_value == 28) {
          tft.drawString("m3/s", 108, 65);
        } else if (uint16_value == 138) {
          tft.drawString("L/h", 108, 65);
        } else if (uint16_value == 17) {
          tft.drawString("L/m", 108, 65);
        } else if (uint16_value == 24) {
          tft.drawString("L/s", 108, 65);
        } else if (uint16_value == 185) {
          tft.drawString("Scf/h", 98, 65);
        } else if (uint16_value == 123) {
          tft.drawString("Scf/m", 98, 65);
        } else if (uint16_value == 186) {
          tft.drawString("Scf/s", 98, 65);
        } else if (uint16_value == 130) {
          tft.drawString("cf/h", 108, 65);
        } else if (uint16_value == 15) {
          tft.drawString("cf/m", 108, 65);
        } else if (uint16_value == 26) {
          tft.drawString("cf/s", 108, 65);
        } else if (uint16_value == 136) {
          tft.drawString("USG/h", 98, 66);
        } else if (uint16_value == 16) {
          tft.drawString("USG/m", 98, 66);
        } else if (uint16_value == 22) {
          tft.drawString("USG/s", 98, 66);
        } else if (uint16_value == 30) {
          tft.drawString("UKG/h", 98, 66);
        } else if (uint16_value == 18) {
          tft.drawString("UKG/m", 98, 66);
        } else if (uint16_value == 137) {
          tft.drawString("UKG/s", 98, 66);
        } else if (uint16_value == 135) {
          tft.drawString("bbl/d", 108, 65);
        } else if (uint16_value == 134) {
          tft.drawString("bbl/h", 108, 65);
        } else if (uint16_value == 79) {
          tft.drawString("ton/d", 108, 65);
        } else if (uint16_value == 78) {
          tft.drawString("ton/h", 108, 65);
        } else if (uint16_value == 77) {
          tft.drawString("ton/m", 108, 65);
        } else if (uint16_value == 76) {
          tft.drawString("kg/d", 108, 65);
        } else if (uint16_value == 75) {
          tft.drawString("kg/h", 108, 65);
        } else if (uint16_value == 74) {
          tft.drawString("kg/m", 108, 65);
        } else if (uint16_value == 73) {
          tft.drawString("kg/s", 108, 65);
        } else if (uint16_value == 72) {
          tft.drawString("g/h", 108, 65);
        } else if (uint16_value == 71) {
          tft.drawString("g/m", 108, 65);
        } else if (uint16_value == 70) {
          tft.drawString("g/s", 108, 65);
        } else if (uint16_value == 83) {
          tft.drawString("lb/d", 108, 65);
        } else if (uint16_value == 82) {
          tft.drawString("lb/h", 108, 65);
        }


        // Total Unit
        tft.setFreeFont(FSS12);
        tft.setTextColor(TFT_NAVY, TFT_WHITE);
        if (uint16_value == 188 || uint16_value == 189 || uint16_value == 190) {
          tft.drawString("Nm3", 258, 180);
        } else if (uint16_value == 29 || uint16_value == 19 || uint16_value == 131 || uint16_value == 28) {
          tft.drawString("m3", 258, 180);
        } else if (uint16_value == 138 || uint16_value == 17 || uint16_value == 24) {
          tft.drawString("L", 258, 180);
        } else if (uint16_value == 185 || uint16_value == 123 || uint16_value == 186) {
          tft.drawString("Scf", 258, 180);
        } else if (uint16_value == 130 || uint16_value == 15 || uint16_value == 26) {
          tft.drawString("cf", 258, 180);
        } else if (uint16_value == 136 || uint16_value == 16 || uint16_value == 22) {
          tft.drawString("USG", 258, 179);
        } else if (uint16_value == 30 || uint16_value == 18 || uint16_value == 137) {
          tft.drawString("UKG", 258, 179);
        } else if (uint16_value == 135 || uint16_value == 134) {
          tft.drawString("bbl", 258, 180);
        } else if (uint16_value == 79 || uint16_value == 78 || uint16_value == 77) {
          tft.drawString("ton", 258, 180);
        } else if (uint16_value == 76 || uint16_value == 75 || uint16_value == 74 || uint16_value == 73) {
          tft.drawString("kg", 258, 180);
        } else if (uint16_value == 72 || uint16_value == 71 || uint16_value == 70) {
          tft.drawString("gram", 258, 180);
        } else if (uint16_value == 83 || uint16_value == 82) {
          tft.drawString("lb", 258, 180);
        }


        // Anlık akış için noktadan sonra kaç basamak olacağını oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x021F, &decpoint);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        // Yüksek ve düşük akış alarm limitlerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0210, &high_alarm_value);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre
 
        modbus_master.read_or_write(1, READ_HOLDING, 0x0212, &low_alarm_value);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre

      }


      if (button_state == press_up) {
        button_state = idle;
        opening_page = true;

        screen_switch = main_screen;

        break;

      } else if (button_state == press_down) {
        button_state = idle;
        opening_page = true;

        screen_switch = main_screen;

        break;

      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        if (password_validity_time > 120) screen_switch = password_screen;  // password geçerlilik süresi devam etmiyorsa şifre ekranına git
        else {
          screen_switch = settings;  // password geçerlilik süresi devam ediyorsa şifre ekranını atla
        }
      }

      // Belirlenen sürede girecek
      if (time_for_main_sreens >= screen_refresh_time_value) {
        time_for_main_sreens = 0;  // saniye sıfırla

        static uint8_t previous_percentage;               // anlık akış yüzdesi
        uint8_t number_of_digit = 0;                      // ekrana yazılacak bamasak sayısı
        static uint8_t previous_flow_digits;              // ekrana yazılacak bamasak sayısı
        uint16_t pos_flow = 215, pos_differantiel = 250;  // Anlık akış değeri başlangıç x koordinatı
        uint8_t character_counter = 0;                    // bamasak hesaplama sayıcısı
        static int32_t differantiel = 0;                  // total ileri akış - total geri akış ham değer
        float differantiel_float = 0;
        static uint8_t previous_differantiel_digits_p, previous_differantiel_digits_n, previous_differantiel_digits_d;  // ekrana yazılacak bamasak sayısı
        char number_buffer[15];                                                                                         // ekrana numara yazmak için buffer

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
        tft.setFreeFont(FSSB12);
        tft.setTextDatum(TR_DATUM);
        tft.setTextColor(TFT_NAVY, TFT_GRAYY);

        // Anlık akış değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0404, &flow);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, flow, flow_address);

        // Anlık akış değerine göre ekranda nokta kaydır
        if (decpoint == 1) {
          if (flow < 10 && flow > -10) decpoint = 1;
          else if (flow < 100 && flow > -100) decpoint = 1;
          else if (flow < 1000 && flow > -1000) decpoint = 1;
          else if (flow < 10000 && flow > -10000) decpoint = 1;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        } else if (decpoint == 2) {
          if (flow < 10 && flow > -10) decpoint = 2;
          else if (flow < 100 && flow > -100) decpoint = 2;
          else if (flow < 1000 && flow > -1000) decpoint = 2;
          else if (flow < 10000 && flow > -10000) decpoint = 2;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        } else if (decpoint == 3) {
          if (flow < 10 && flow > -10) decpoint = 3;
          else if (flow < 100 && flow > -100) decpoint = 3;
          else if (flow < 1000 && flow > -1000) decpoint = 3;
          else if (flow < 10000 && flow > -10000) decpoint = 2;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        } else if (decpoint == 4) {
          if (flow < 10 && flow > -10) decpoint = 4;
          else if (flow < 100 && flow > -100) decpoint = 4;
          else if (flow < 1000 && flow > -1000) decpoint = 3;
          else if (flow < 10000 && flow > -10000) decpoint = 2;
          else if (flow < 100000 && flow > -100000) decpoint = 1;
          else if (flow < 1000000 && flow > -1000000) decpoint = 0;
        }

        if (decpoint == 0) {
          sprintf(flow_buffer, "%.0f", flow);
        } else if (decpoint == 1) {
          sprintf(flow_buffer, "%.1f", flow);
        } else if (decpoint == 2) {
          sprintf(flow_buffer, "%.2f", flow);
        } else if (decpoint == 3) {
          sprintf(flow_buffer, "%.3f", flow);
        } else if (decpoint == 4) {
          sprintf(flow_buffer, "%.4f", flow);
        }

        tft.setTextPadding(100);
        tft.drawString(flow_buffer, 95, 55);  // Sayıyı ekrana yazdır
        tft.setTextPadding(0);

        tft.setFreeFont(FSS12);

         //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        tft.setTextDatum(TL_DATUM);  // Sağa yaslı hizalama
        // if (theme_color == dark_theme) {
        //   tft.setTextColor(TFT_SILVER, TFT_BLACK);
        // } else {
        //   tft.setTextColor(TFT_BLACK, TFT_CREAM);
        // }

        // Alarm durumunu kontrol et ve ekrana bas
        
        if (flow > high_alarm_value) {
          alarm_state =  0b00000100;
        } else if (flow < low_alarm_value){
          alarm_state =  0b00001000;
        } else {
          alarm_state = 0;
        }

        // alarm durumunu ekrana bas
        if (screen_switch == main_screen || screen_switch == second_screen ) {
          if (alarm_state == 0) {
            if (previous_alarm_state != alarm_state || page_change == true) {
              tft.setTextColor(TFT_NAVY, TFT_WHITE);
              tft.drawString("NORMAL      ", 235, 220, FONT2);
              previous_alarm_state = alarm_state;             // önceki Alarm değerini koru
            }

          } else {  // Alarm yanıp sönme animasyonu için
            alarm_animation = !alarm_animation;

            if (theme_color == dark_theme) {
              if (alarm_animation) {
                tft.setTextColor(TFT_SILVER, TFT_BLACK);
              } else {
                tft.setTextColor(TFT_BLACK, TFT_SILVER);
              }
            } else {
              if (alarm_animation) {
                tft.setTextColor(TFT_WHITE, TFT_NAVY);
              } else {
                tft.setTextColor(TFT_NAVY, TFT_WHITE);
              }
            }

            bool alarm_counter_flag = false;
            while (alarm_counter < 6) {
              if ((alarm_state & (1 << 0)) && alarm_counter == 0) {  // alarm registerının 0. bitini kontrol et
                tft.drawString("ERR - 001", 235, 220, FONT2);         // Empt Pipe Alarm - Boş boru alarmı
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 1)) && alarm_counter == 1) {  // alarm registerının 1. bitini kontrol et
                tft.drawString("ERR - 002", 235, 220, FONT2);                // SYS Alarm (isimlendirilecek)
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 2)) && alarm_counter == 2) {  // alarm registerının 2. bitini kontrol et
                tft.drawString("ERR - 003", 235, 220, FONT2);              // High Flow Alarm - Yüksek akış alarmı
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 3)) && alarm_counter == 3) {  // alarm registerının 3. bitini kontrol et
                tft.drawString("ERR - 004", 235, 220, FONT2);                // Low Flow Alarm - Düşük akış alarmı
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 4)) && alarm_counter == 4) {  // alarm registerının 4. bitini kontrol et
                tft.drawString("ERR - 005", 235, 220, FONT2);                // Excitation Drive Alarm - DRV (isimlendirilecek)
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if ((alarm_state & (1 << 5)) && alarm_counter == 5) {  // alarm registerının 5. bitini kontrol et
                tft.drawString("ERR - 006", 235, 220, FONT2);               // Eeprom Alarm (isimlendirilecek)
                alarm_counter++;
                alarm_counter_flag = true;
                break;
              } else if (alarm_counter_flag == false){
                alarm_counter = -1;
                alarm_counter_flag = true;
              }
              alarm_counter++;
            }

            if (alarm_counter >= 5) alarm_counter = 0;
            
            previous_alarm_state = alarm_state;  // önceki Alarm değerini koru
          }
          if (theme_color == dark_theme) {
            tft.setTextColor(TFT_WHITE, TFT_BLACK);
          } else {
            tft.setTextColor(TFT_NAVY, TFT_WHITE);
          }
        }

        // // Alarm durumuna göre dijital çıkışları organize et
        // if (alarm_state & (1 << 0)) {  // alarm registerının 0. bitini kontrol et
        //   // Empt Pipe Alarm - Boş boru alarmı
        //   if (D_out_2_alarm_state == 1) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 1) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // Empt Pipe Alarm - Boş boru alarmı
        //   if (D_out_2_alarm_state == 1) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 1) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (alarm_state & (1 << 1)) {  // alarm registerının 1. bitini kontrol et
        //   // SYS Alarm (isimlendirilecek)
        //   if (D_out_2_alarm_state == 2) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 2) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // SYS Alarm (isimlendirilecek)
        //   if (D_out_2_alarm_state == 2) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 2) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (alarm_state & (1 << 2)) {  // alarm registerının 2. bitini kontrol et
        //   // High Flow Alarm - Yüksek akış alarmı
        //   if (D_out_2_alarm_state == 4) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 4) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // High Flow Alarm - Yüksek akış alarmı
        //   if (D_out_2_alarm_state == 4) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 4) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (alarm_state & (1 << 3)) {  // alarm registerının 3. bitini kontrol et
        //   // Low Flow Alarm - Düşük akış alarmı
        //   if (D_out_2_alarm_state == 8) {
        //     digitalWrite(pulse_pin, 1);
        //   }
        //   if (D_out_3_alarm_state == 8) {
        //     digitalWrite(relay_pin, 1);
        //   }
        // } else {
        //   // Low Flow Alarm - Düşük akış alarmı
        //   if (D_out_2_alarm_state == 8) {
        //     digitalWrite(pulse_pin, 0);
        //   }
        //   if (D_out_3_alarm_state == 8) {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }
        // if (D_out_2_alarm_state == 16) {
        //   if (flow < 0) {
        //     digitalWrite(pulse_pin, 1);
        //   } else {
        //     digitalWrite(pulse_pin, 0);
        //   }
        // }
        // if (D_out_3_alarm_state == 16) {
        //   if (flow < 0) {
        //     digitalWrite(relay_pin, 1);
        //   } else {
        //     digitalWrite(relay_pin, 0);
        //   }
        // }

        tft.setTextDatum(TR_DATUM);  // Sağa yaslı hizalama

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Pressure değerini bas
        modbus_master.read_or_write(1, READ_HOLDING, 0x0423, &pressure);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, pressure, pressure_address);  // holding registera yaz

        sprintf(pressure_buffer, "%.2f", pressure);

        tft.setTextColor(TFT_NAVY, TFT_GRAYY);
        tft.setTextPadding(70);
        tft.drawString(pressure_buffer, 255, 55);
        tft.setTextPadding(0);

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Density değeri bas
        modbus_master.read_or_write(1, READ_HOLDING, 0x0427, &density_modbus);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, density_modbus, density_address);

        sprintf(density_buffer, "%.3f", density_modbus);

        tft.setTextPadding(71);
        tft.drawString(density_buffer, 95, 109);
        tft.setTextPadding(0);

        // tft.drawString(density_buffer, 95, 104, FONT4);  // Sayıyı ekrana yazdır

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Temperature değerini bas
        modbus_master.read_or_write(1, READ_HOLDING, 0x0425, &temperature);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, temperature, temperature_address);  // holding registera yaz

        sprintf(temperature_buffer, "%.1f", temperature);

        tft.setTextPadding(70);
        tft.drawString(temperature_buffer, 255, 109);
        tft.setTextPadding(0);

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Toplam değeri bas
        tft.setFreeFont(FSS18);
        tft.setTextColor(TFT_NAVY, TFT_WHITE);

        modbus_master.read_or_write(1, READ_HOLDING, 0x040A, &total_differential);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, total_differential, total_differential_address);

        divider_value = 100;  // silinecek
        if (divider_value == 1) {
          sprintf(total_buffer, "%.0f", total_differential);
        } else if (divider_value == 10) {
          sprintf(total_buffer, "%.1f", total_differential);
        } else if (divider_value == 100) {
          sprintf(total_buffer, "%.2f", total_differential);
        } else if (divider_value == 1000) {
          sprintf(total_buffer, "%.3f", total_differential);
        }

        tft.setTextPadding(205);
        tft.drawString(total_buffer, 241, 170);
        tft.setTextPadding(0);

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // yüzde değerini oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x0402, &percentage);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        percentage_bar = percentage;

        if (percentage_bar < 0) percentage_bar = percentage_bar * -1;  // eksi ile barı dolduramayacağı için pozitif yapılıyor

        if (percentage_bar > 100) percentage_bar = 100;  // Bar ın taşmaması için limitle

        percentage_V = percentage;
        if (percentage_V > 100) percentage_V = 100;  // voltaj çıkışı 0 - 10v arasında olduğu için min max değerler sınırlandırılmıştır
        else if (percentage_V < -100) percentage_V = -100;
        // V değerini akışın yüzdesini baz alarak hesapla ve seçilen biçime göre çıkış ver
        if (analog_out_3_type == v_0_10) {                         // Akım çıkışı 4 - 20 mA seçildiyse
          if (percentage_V < 0) percentage_V = percentage_V * -1;  // Ters yöndeki akışı hesaplamalar için pozitife dönüştür
          if (percentage_V > 100) percentage_V = 100;              // 20.50 mA da sınırlaması için
          V = percentage_V * 10 / 100;
        } else if (analog_out_3_type == v_0_5_10) {  // Akım çıkışı 4 - 12 - 20 mA seçildiyse
          V = (percentage_V * 5 / 100) + 5;
        }

        dac_v_value = mapFloat(V, 0, 10, lower_limit_VDC, upper_limit_VDC);  // 0 - 10 VDC arasını dac için 0 - 255 e uyarla
        // dacWrite(DAC_2_PIN_V, dac_v_value);

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // mA değerini oku, slave olarak registerda göstermesi için
        tft.setTextColor(TFT_WHITE, TFT_BLUEE);

        modbus_master.read_or_write(1, READ_HOLDING, 791, &mA_out);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, mA_out, mA_out_address);

        dac_ma_value = mapFloat(mA_out, 4, 21, lower_limit_mA, upper_limit_mA);  // 4 - 20 mA arasını dac için 0 - 255 e uyarla
        MCP.setValue(dac_ma_value);

        sprintf(ma_buffer, "%.2f", mA_out);
        tft.setTextPadding(100);
        tft.drawString(ma_buffer, 85, 6, FONT4);
        tft.setTextPadding(0);

        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Frekans değerini bas
        modbus_master.read_or_write(1, READ_HOLDING, 0x0408, &sensor_frequency);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        sprintf(sensor_frequency_buffer, "%.1f", sensor_frequency);
        tft.setTextPadding(100);
        tft.drawString(sensor_frequency_buffer, 270, 6, FONT4);
        tft.setTextPadding(0);

        tft.setTextDatum(TL_DATUM);


        //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

        // Velocity değerini oku, slave olarak registerda göstermesi için
        modbus_master.read_or_write(1, READ_HOLDING, 0x030A, &flow_rate);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        modbus_slave.write_to_holding_registers(holdingRegisters, flow_rate, flow_rate_address);

        page_change = false;  // sayfa değişimi olmadığını belirtmek için
      }


      break;

    case password_screen:

      if (opening_page == true) {
        opening_page = false;

        tft.fillScreen(TFT_BLACK);

        tft.setTextColor(TFT_ORANGE, TFT_BLACK);
        tft.setFreeFont(FSS18);
        if (language == English) {
          tft.drawString(english[0], 81, 40);  // Password
          tft.setFreeFont(FSS9);
          tft.drawString(english[1], 69, 190);  // Please Enter Password
        } else if (language == Turkish) {
          tft.drawString(turkish[0], 125, 40);  // Sifre
          tft.setFreeFont(FSS9);
          tft.drawString(turkish[1], 100, 190);  // Lutfen Sifre girin
        }

        tft.drawWideLine(270, 95, 50, 95, 3, TFT_SILVER, TFT_SILVER);  // çizgi

        tft.pushImage(70, 120, 40, 40, locckk);  // kilit ikonu

        draw_char(0, 115, 121, TFT_BLACK, TFT_WHITE);
        draw_char(0, 148, 121, TFT_WHITE, TFT_BLACK);
        draw_char(0, 181, 121, TFT_WHITE, TFT_BLACK);
        draw_char(0, 214, 121, TFT_WHITE, TFT_BLACK);

        digit = 0;

        memset(number, 0, sizeof(number));
      }

      // Şifre ekranında işlem yapılmadıysa 30 Sn sonra ana ekrana dön
      if (second_for_menu > 30) {
        second_for_menu = 0;  // saniye sıfırla
        screen_switch = main_screen;
        opening_page = true;
      }

      if (button_state == press_up) {
        button_state = idle;
        if (digit == 0) {
          number[0]++;
          if (number[0] > 9) number[0] = 0;
          draw_char(number[0], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 1) {
          number[1]++;
          if (number[1] > 9) number[1] = 0;
          draw_char(number[1], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 2) {
          number[2]++;
          if (number[2] > 9) number[2] = 0;
          draw_char(number[2], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 3) {
          number[3]++;
          if (number[3] > 9) number[3] = 0;
          draw_char(number[3], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        }


      } else if (button_state == press_down) {
        button_state = idle;
        digit++;
        if (digit > 3) digit = 0;

        if (digit == 0) {
          draw_char(number[3], 115 + 3 * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[0], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 1) {
          draw_char(number[0], 115 + (digit - 1) * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[1], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 2) {
          draw_char(number[1], 115 + (digit - 1) * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[2], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 3) {
          draw_char(number[2], 115 + (digit - 1) * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[3], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        }



      } else if (button_state == press_enter) {
        button_state = idle;
        cursor = 6;                                                                           // menu ekranında kursor basic_settings den başlayacak
        previous_cursor = 6;                                                                  // menu ekranında kursor basic_settings den başlayacak
        uint16_t password = number[0] * 1000 + number[1] * 100 + number[2] * 10 + number[3];  // girilen şifreyi password değişkenine ata
        main_password = EEPROM.readUShort(main_password_address);

        if (main_password == password || master_password == password) {
          tft.setFreeFont(FSS18);
          tft.setTextColor(TFT_DARKGREEN, TFT_BLACK);
          tft.fillRect(20, 190, 300, 20, TFT_BLACK);
          if (language == English) {
            tft.drawString(english[0], 81, 40);  // password
            tft.setFreeFont(FSSB9);
            tft.drawString(english[2], 130, 190);  // done

          } else if (language == Turkish) {
            tft.drawString(turkish[0], 125, 40);  // Sifre
            tft.setFreeFont(FSSB9);
            tft.drawString(turkish[2], 115, 190);  // onaylandı
          }
          tft.setFreeFont(FSS18);
          delay(1500);
          screen_switch = settings;
          opening_page = true;
          password_validity_time = 0;  // şifrenin 2 dk geçerlilik süresi başladı
        } else {

          tft.fillRect(80, 190, 200, 20, TFT_BLACK);
          tft.setTextColor(TFT_RED, TFT_BLACK);
          tft.setFreeFont(FSS9);
          if (language == English) {
            tft.drawString(english[3], 45, 190);  // Wrong Password !  Try Again
            tft.setFreeFont(FSS18);
            tft.drawString(english[0], 81, 40);  // Password
            delay(1500);
            tft.setTextColor(TFT_ORANGE, TFT_BLACK);
            tft.drawString(english[0], 81, 40);  // Password
          } else if (language == Turkish) {
            tft.drawString(turkish[3], 45, 190);  // Şifre yanlış Tekrar deneyin
            tft.setFreeFont(FSS18);
            tft.drawString(turkish[0], 125, 40);  // Sifre
            delay(1500);
            tft.setTextColor(TFT_ORANGE, TFT_BLACK);
            tft.drawString(turkish[0], 125, 40);  // Sifre
          }
        }

      } else if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = main_screen;
      }

      break;

    case settings:


      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = main_screen;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        if (cursor == advanced_settings) {
          screen_switch = cursor;  // kursor nerdeyse o ayara git
          cursor = preset;
          first_text = true;
        } else {
          screen_switch = cursor;  // kursor nerdeyse o ayara git
        }
        opening_page = true;
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(icons_main, 75, left_aligned, 4, 5, 6, 7, 8, 9, 10, basic_settings, information);

      break;

    case basic_settings:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        opening_page = true;

        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(basic_settings_icon, 4, 75, left_aligned, false, 154, 15, 16, 17, quick_setup, sensor_size);

      break;

    case languages:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = basic_settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;

        if (cursor == english_language) language = English;
        else language = Turkish;

        EEPROM.writeUShort(language_address, language);
        EEPROM.commit();  // kaydet

        tick_location = language + 1;

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        tick_location = language + 1;
      }

      bar_select(basic_settings_icon, 15, 138, middle_aligned, true, 78, 79, english_language, turkish_language);

      break;

    case flow_parameters:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = basic_settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        opening_page = true;
        if (cursor == calculation_method) {
          cursor = liquid_volume;
          first_text = true;
        } else if (cursor == flow_and_total_unit) {
          first_text = true;
        }

        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(basic_settings_icon, 16, 75, left_aligned, false, 269, 37, 109, 33, 34, 36, fluid_type, flow_cut_off);

      break;

    case fluid_type:
    case _fluid_type:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        if (previous_screen_switch == quick_setup) {
          screen_switch = quick_setup;
          previous_screen_switch = 0;
        } else {
          screen_switch = flow_parameters;
        }                                 

        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        if (cursor == liquid) {
          if (uint16_value <= 19) {
          } else if (uint16_value >= 256) {
            uint16_value = uint16_value - 256;
            tick_location = 1;
          }
        } else if (cursor == gas) {
          if (uint16_value <= 19) {
            uint16_value = uint16_value + 256;
            tick_location = 2;
          } else if (uint16_value >= 256) {
          }
        }

        modbus_master.read_or_write(1, WRITE_MULTI, 0x0202, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        modbus_master.read_or_write(1, READ_HOLDING, 0x0202, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        if (uint16_value <= 19) tick_location = 1;
        else if (uint16_value >= 256) tick_location = 2;
      }

      bar_select(basic_settings_icon, 269, 138, middle_aligned, true, 270, 271, liquid, gas);

      break;

    case flow_and_total_unit:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        screen_switch = flow_parameters;

        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        uint16_t pulse_unit;

        // hacim değerleri volume
        if (cursor == nm3_h) {
          uint16_value = 188;
          pulse_unit = 172;
        } else if (cursor == nm3_m) {
          uint16_value = 189;
          pulse_unit = 172;
        } else if (cursor == nm3_s) {
          uint16_value = 190;
          pulse_unit = 172;
        } else if (cursor == m3_d) {
          uint16_value = 29;
          pulse_unit = 43;
        } else if (cursor == m3_h) {
          uint16_value = 19;
          pulse_unit = 43;
        } else if (cursor == m3_m) {
          uint16_value = 131;
          pulse_unit = 43;
        }

        else if (cursor == m3_s) {
          uint16_value = 28;
          pulse_unit = 43;
        } else if (cursor == l_h) {
          uint16_value = 138;
          pulse_unit = 43;
        } else if (cursor == l_m) {
          uint16_value = 17;
          pulse_unit = 43;
        } else if (cursor == l_s) {
          uint16_value = 24;
          pulse_unit = 43;
        } else if (cursor == usg_h) {
          uint16_value = 136;
          pulse_unit = 40;
        } else if (cursor == usg_m) {
          uint16_value = 16;
          pulse_unit = 40;
        }

        else if (cursor == usg_s) {
          uint16_value = 22;
          pulse_unit = 40;
        } else if (cursor == ukg_h) {
          uint16_value = 30;
          pulse_unit = 42;
        } else if (cursor == ukg_m) {
          uint16_value = 18;
          pulse_unit = 42;
        } else if (cursor == ukg_s) {
          uint16_value = 137;
          pulse_unit = 42;
        } else if (cursor == bbl_d) {
          uint16_value = 135;
          pulse_unit = 46;
        } else if (cursor == bbl_h) {
          uint16_value = 134;
          pulse_unit = 46;
        }

        else if (cursor == scf_h) {
          uint16_value = 185;
          pulse_unit = 168;
        } else if (cursor == scf_m) {
          uint16_value = 123;
          pulse_unit = 168;
        } else if (cursor == scf_s) {
          uint16_value = 186;
          pulse_unit = 168;
        } else if (cursor == cf_h) {
          uint16_value = 130;
          pulse_unit = 112;
        } else if (cursor == cf_m) {
          uint16_value = 15;
          pulse_unit = 112;
        } else if (cursor == cf_s) {
          uint16_value = 26;
          pulse_unit = 112;
        }

        // kütle değerleri mass
        else if (cursor == g_h) {
          uint16_value = 72;
          pulse_unit = 43;
        } else if (cursor == g_m) {
          uint16_value = 71;
          pulse_unit = 43;
        } else if (cursor == g_s) {
          uint16_value = 70;
          pulse_unit = 43;
        } else if (cursor == kg_d) {
          uint16_value = 76;
          pulse_unit = 61;
        } else if (cursor == kg_h) {
          uint16_value = 75;
          pulse_unit = 61;
        } else if (cursor == kg_m) {
          uint16_value = 74;
          pulse_unit = 61;
        }

        else if (cursor == kg_s) {
          uint16_value = 73;
          pulse_unit = 61;
        } else if (cursor == t_d) {
          uint16_value = 79;
          pulse_unit = 62;
        } else if (cursor == t_h) {
          uint16_value = 78;
          pulse_unit = 62;
        } else if (cursor == t_m) {
          uint16_value = 77;
          pulse_unit = 62;
        } else if (cursor == lb_d) {
          uint16_value = 83;
          pulse_unit = 63;
        } else if (cursor == lb_h) {
          uint16_value = 82;
          pulse_unit = 63;
        }

        // Flow ve total unit
        modbus_master.read_or_write(1, WRITE_MULTI, 0x021C, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        // Pulse unit de flow unit e bağlı olarak değişecek
        modbus_master.read_or_write(1, WRITE_MULTI, 0x0247, &pulse_unit);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        // hacim değerleri volume
        if (uint16_value == 188) tick_location = 1;
        else if (uint16_value == 189) tick_location = 2;
        else if (uint16_value == 190) tick_location = 3;
        else if (uint16_value == 29) tick_location = 4;
        else if (uint16_value == 19) tick_location = 5;
        else if (uint16_value == 131) tick_location = 6;

        else if (uint16_value == 28) tick_location = 1;
        else if (uint16_value == 138) tick_location = 2;
        else if (uint16_value == 17) tick_location = 3;
        else if (uint16_value == 24) tick_location = 4;
        else if (uint16_value == 136) tick_location = 5;
        else if (uint16_value == 16) tick_location = 6;

        else if (uint16_value == 22) tick_location = 1;
        else if (uint16_value == 30) tick_location = 2;
        else if (uint16_value == 18) tick_location = 3;
        else if (uint16_value == 137) tick_location = 4;
        else if (uint16_value == 135) tick_location = 5;
        else if (uint16_value == 134) tick_location = 6;

        else if (uint16_value == 185) tick_location = 1;
        else if (uint16_value == 123) tick_location = 2;
        else if (uint16_value == 186) tick_location = 3;
        else if (uint16_value == 130) tick_location = 4;
        else if (uint16_value == 15) tick_location = 5;
        else if (uint16_value == 26) tick_location = 6;

        // kütle değerleri mass
        else if (uint16_value == 72) tick_location = 1;
        else if (uint16_value == 71) tick_location = 2;
        else if (uint16_value == 70) tick_location = 3;
        else if (uint16_value == 76) tick_location = 4;
        else if (uint16_value == 75) tick_location = 5;
        else if (uint16_value == 74) tick_location = 6;

        else if (uint16_value == 73) tick_location = 1;
        else if (uint16_value == 79) tick_location = 2;
        else if (uint16_value == 78) tick_location = 3;
        else if (uint16_value == 77) tick_location = 4;
        else if (uint16_value == 83) tick_location = 5;
        else if (uint16_value == 82) tick_location = 6;

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        previous_cursor = 100;
        modbus_master.read_or_write(1, READ_HOLDING, 0x021C, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        if (uint16_value >= 70 && uint16_value <= 83) mass_or_volume = _mass;
        else mass_or_volume = _volume;
      }

      if (mass_or_volume == _mass) {

        if (opening_page == true) {

          if (uint16_value == 70 || uint16_value == 71
              || uint16_value == 72 || uint16_value == 74
              || uint16_value == 75 || uint16_value == 76) cursor = g_h;
          else cursor = kg_s;
        }

        if (cursor < g_h) {
          opening_page = true;
          first_text = true;
          cursor = kg_s;
        } else if (cursor > lb_h) {
          opening_page = true;
          first_text = true;
          cursor = g_h;
        } else if (cursor == kg_m && previous_cursor == kg_s) {
          opening_page = true;
          first_text = true;
        } else if (cursor == kg_s && previous_cursor == kg_m) {
          opening_page = true;
          first_text = true;
        }

        if (cursor >= g_h && cursor <= kg_m) {

          if (opening_page == true) {

            if (uint16_value == 72) tick_location = 1;
            else if (uint16_value == 71) tick_location = 2;
            else if (uint16_value == 70) tick_location = 3;
            else if (uint16_value == 76) tick_location = 4;
            else if (uint16_value == 75) tick_location = 5;
            else if (uint16_value == 74) tick_location = 6;
            else tick_location = 0;
          }

          bar_select(basic_settings_icon, 109, 140, middle_aligned, true, 211, 212, 213, 214, 215, 216, g_h, kg_m);

          if (first_text == true) {
            first_text = false;

            tft.setFreeFont(FSS9);
            tft.setTextColor(TFT_BLACK, TFT_WHITE);
            tft.drawString("1/2", 271, 13);
          }

        } else if (cursor >= kg_s && cursor <= lb_h) {
          if (opening_page == true) {

            if (uint16_value == 73) tick_location = 1;
            else if (uint16_value == 79) tick_location = 2;
            else if (uint16_value == 78) tick_location = 3;
            else if (uint16_value == 77) tick_location = 4;
            else if (uint16_value == 83) tick_location = 5;
            else if (uint16_value == 82) tick_location = 6;
            else tick_location = 0;
          }
          bar_select(basic_settings_icon, 109, 140, middle_aligned, true, 217, 218, 219, 220, 221, 222, kg_s, lb_h);

          if (first_text == true) {
            first_text = false;

            tft.setFreeFont(FSS9);
            tft.setTextColor(TFT_BLACK, TFT_WHITE);
            tft.drawString("2/2", 271, 13);
          }
        }

      } else {

        if (opening_page == true) {

          if (uint16_value == 188 || uint16_value == 189
              || uint16_value == 190 || uint16_value == 29
              || uint16_value == 19 || uint16_value == 131) cursor = nm3_h;
          else if (uint16_value == 28 || uint16_value == 138
                   || uint16_value == 17 || uint16_value == 24
                   || uint16_value == 136 || uint16_value == 16) cursor = m3_s;
          else if (uint16_value == 22 || uint16_value == 30
                   || uint16_value == 18 || uint16_value == 137
                   || uint16_value == 135 || uint16_value == 123) cursor = usg_s;
          else if (uint16_value == 186 || uint16_value == 130
                   || uint16_value == 15 || uint16_value == 74
                   || uint16_value == 75 || uint16_value == 26) cursor = scf_h;
        }

        if (cursor < nm3_h) {
          opening_page = true;
          first_text = true;
          cursor = cf_s;
        } else if (cursor > cf_s) {
          opening_page = true;
          first_text = true;
          cursor = nm3_h;
        } else if (cursor == m3_m && previous_cursor == m3_s) {
          opening_page = true;
          first_text = true;
        } else if (cursor == m3_s && previous_cursor == m3_m) {
          opening_page = true;
          first_text = true;
        } else if (cursor == usg_m && previous_cursor == usg_s) {
          opening_page = true;
          first_text = true;
        } else if (cursor == usg_s && previous_cursor == usg_m) {
          opening_page = true;
          first_text = true;
        } else if (cursor == bbl_h && previous_cursor == scf_h) {
          opening_page = true;
          first_text = true;
        } else if (cursor == scf_h && previous_cursor == bbl_h) {
          opening_page = true;
          first_text = true;
        }

        if (cursor >= nm3_h && cursor <= m3_m) {

          if (opening_page == true) {
            if (uint16_value == 188) tick_location = 1;
            else if (uint16_value == 189) tick_location = 2;
            else if (uint16_value == 190) tick_location = 3;
            else if (uint16_value == 29) tick_location = 4;
            else if (uint16_value == 19) tick_location = 5;
            else if (uint16_value == 131) tick_location = 6;
            else tick_location = 0;
          }

          bar_select(basic_settings_icon, 109, 130, middle_aligned, true, 187, 188, 189, 190, 191, 192, nm3_h, m3_m);

          if (first_text == true) {
            first_text = false;

            tft.setFreeFont(FSS9);
            tft.setTextColor(TFT_BLACK, TFT_WHITE);
            tft.drawString("1/4", 271, 13);
          }

        } else if (cursor >= m3_s && cursor <= usg_m) {
          if (opening_page == true) {

            if (uint16_value == 28) tick_location = 1;
            else if (uint16_value == 138) tick_location = 2;
            else if (uint16_value == 17) tick_location = 3;
            else if (uint16_value == 24) tick_location = 4;
            else if (uint16_value == 136) tick_location = 5;
            else if (uint16_value == 16) tick_location = 6;
            else tick_location = 0;
          }
          bar_select(basic_settings_icon, 109, 130, middle_aligned, true, 193, 194, 195, 196, 197, 198, m3_s, usg_m);

          if (first_text == true) {
            first_text = false;

            tft.setFreeFont(FSS9);
            tft.setTextColor(TFT_BLACK, TFT_WHITE);
            tft.drawString("2/4", 271, 13);
          }
        } else if (cursor >= usg_s && cursor <= bbl_h) {
          if (opening_page == true) {

            if (uint16_value == 22) tick_location = 1;
            else if (uint16_value == 30) tick_location = 2;
            else if (uint16_value == 18) tick_location = 3;
            else if (uint16_value == 137) tick_location = 4;
            else if (uint16_value == 135) tick_location = 5;
            else if (uint16_value == 134) tick_location = 6;
            else tick_location = 0;
          }
          bar_select(basic_settings_icon, 109, 125, middle_aligned, true, 199, 200, 201, 202, 203, 204, usg_s, bbl_h);

          if (first_text == true) {
            first_text = false;

            tft.setFreeFont(FSS9);
            tft.setTextColor(TFT_BLACK, TFT_WHITE);
            tft.drawString("3/4", 271, 13);
          }
        } else if (cursor >= scf_h && cursor <= cf_s) {
          if (opening_page == true) {

            if (uint16_value == 185) tick_location = 1;
            else if (uint16_value == 123) tick_location = 2;
            else if (uint16_value == 186) tick_location = 3;
            else if (uint16_value == 130) tick_location = 4;
            else if (uint16_value == 15) tick_location = 5;
            else if (uint16_value == 26) tick_location = 6;
            else tick_location = 0;
          }
          bar_select(basic_settings_icon, 109, 135, middle_aligned, true, 205, 206, 207, 208, 209, 210, scf_h, cf_s);

          if (first_text == true) {
            first_text = false;

            tft.setFreeFont(FSS9);
            tft.setTextColor(TFT_BLACK, TFT_WHITE);
            tft.drawString("4/4", 271, 13);
          }
        }
      }

      break;

    case flow_range:
    case _flow_range:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x020C, &read_or_write_number);
        delay(time_after_communication);                                                // iki modbus haberleşmesi arası beklenecek min süre
        number_entry_opening_page(read_or_write_number, positive, non_decimal_number);  // Okunan değeri bulunduran değişkeni ekrana basamak basamak yaz

        tft.setFreeFont(FSSB12);
        if (language == English) {
          tft.drawString(english[33], 90, 28);  // Flow Range
          tft.setFreeFont(FSS12);
          tft.drawString(english[69], 33, 190);  // Range
        } else if (language == Turkish) {
          tft.drawString(turkish[33], 82, 28);  // ölçme Araligi
          tft.setFreeFont(FSS12);
          tft.drawString(turkish[69], 42, 190);  // Aralik
        }
        tft.drawString("= 0.0001 - 99999", 109, 190);

        // // Akış birimi oku
        modbus_master.read_or_write(1, READ_HOLDING, 0x021C, &flow_unit_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        tft.setFreeFont(FSS9);

        if (flow_unit_value == 188) {
          tft.drawString("Nm3/h", 239, 122);
        } else if (flow_unit_value == 189) {
          tft.drawString("Nm3/m", 239, 122);
        } else if (flow_unit_value == 190) {
          tft.drawString("Nm3/s", 239, 122);
        } else if (flow_unit_value == 29) {
          tft.drawString("m3/d", 239, 122);
        } else if (flow_unit_value == 19) {
          tft.drawString("m3/h", 239, 122);
        } else if (flow_unit_value == 131) {
          tft.drawString("m3/m", 239, 122);
        } else if (flow_unit_value == 28) {
          tft.drawString("m3/s", 239, 122);
        } else if (flow_unit_value == 138) {
          tft.drawString("L/h", 239, 122);
        } else if (flow_unit_value == 17) {
          tft.drawString("L/m", 239, 122);
        } else if (flow_unit_value == 24) {
          tft.drawString("L/s", 239, 122);
        } else if (flow_unit_value == 185) {
          tft.drawString("Scf/h", 239, 122);
        } else if (flow_unit_value == 123) {
          tft.drawString("Scf/m", 239, 122);
        } else if (flow_unit_value == 186) {
          tft.drawString("Scf/s", 239, 122);
        } else if (flow_unit_value == 130) {
          tft.drawString("cf/h", 239, 122);
        } else if (flow_unit_value == 15) {
          tft.drawString("cf/m", 239, 122);
        } else if (flow_unit_value == 26) {
          tft.drawString("cf/s", 239, 122);
        } else if (flow_unit_value == 136) {
          tft.drawString("USG/h", 239, 122);
        } else if (flow_unit_value == 16) {
          tft.drawString("USG/m", 239, 122);
        } else if (flow_unit_value == 22) {
          tft.drawString("USG/s", 239, 122);
        } else if (flow_unit_value == 30) {
          tft.drawString("UKG/h", 239, 122);
        } else if (flow_unit_value == 18) {
          tft.drawString("UKG/m", 239, 122);
        } else if (flow_unit_value == 137) {
          tft.drawString("UKG/s", 239, 122);
        } else if (flow_unit_value == 135) {
          tft.drawString("bbl/d", 239, 122);
        } else if (flow_unit_value == 134) {
          tft.drawString("bbl/h", 239, 122);
        } else if (flow_unit_value == 79) {
          tft.drawString("ton/d", 239, 122);
        } else if (flow_unit_value == 78) {
          tft.drawString("ton/h", 239, 122);
        } else if (flow_unit_value == 77) {
          tft.drawString("ton/m", 239, 122);
        } else if (flow_unit_value == 76) {
          tft.drawString("kg/d", 239, 122);
        } else if (flow_unit_value == 75) {
          tft.drawString("kg/h", 239, 122);
        } else if (flow_unit_value == 74) {
          tft.drawString("kg/m", 239, 122);
        } else if (flow_unit_value == 73) {
          tft.drawString("kg/s", 239, 122);
        } else if (flow_unit_value == 72) {
          tft.drawString("g/h", 239, 122);
        } else if (flow_unit_value == 71) {
          tft.drawString("g/m", 239, 122);
        } else if (flow_unit_value == 70) {
          tft.drawString("g/s", 239, 122);
        } else if (flow_unit_value == 83) {
          tft.drawString("lb/d", 239, 122);
        } else if (flow_unit_value == 82) {
          tft.drawString("lb/h", 239, 122);
        }
      }

      // Buton kontrolü
      if (button_state == press_esc) {
        button_state = idle;

        opening_page = true;

        if (previous_screen_switch == quick_setup) {
          screen_switch = quick_setup;
          previous_screen_switch = 0;
        } else {
          screen_switch = flow_parameters;
        }

      } else if (button_state == press_enter) {
        button_state = idle;

        number_entry();  // basamaklardaki rakamları read_or_write_number global değişkenine yazar

        if (read_or_write_number >= 0.000095 && read_or_write_number <= 99999) {  // Girilen sayı aralıktaysa registera yaz range yazısını 1 sn yeşil yap
          modbus_master.read_or_write(1, WRITE_MULTI, 0x020C, &read_or_write_number);
          delay(time_after_communication);            // iki modbus haberleşmesi arası beklenecek min süre
          tft.fillRect(80, 163, 150, 18, TFT_WHITE);  // Arka plan temizle
          tft.setTextColor(TFT_DARKGREEN, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[2], 135, 162);  // done !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 33, 190);  // Range
            tft.drawString("= 0.0001 - 99999", 109, 190);
          } else if (language == Turkish) {
            tft.drawString(turkish[2], 112, 162);  // onaylandi !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 42, 190);  // Aralik
            tft.drawString("= 0.0001 - 99999", 109, 190);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);  // done !
        } else {                                                    // Girilen sayı aralıkta değilse registera yazma range yazısını kırmızı yap

          tft.setTextColor(TFT_RED, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[73], 105, 162);  // out of range
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 33, 190);  // Range
            tft.drawString("= 0.0001 - 99999", 109, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[73], 95, 162);  // araligin disinda
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 42, 190);  // Aralik
            tft.drawString("= 0.0001 - 99999", 109, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);  // done !
        }


      } else if (button_state == press_up) {
        button_state = idle;

        increase_digit_number();
      } else if (button_state == press_down) {
        button_state = idle;

        digit++;
      }
      cursor_movement();  // Basamak altı kısa kırmızı çizginin hareklerini gerçekleştir

      break;

    case decimal_point:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x021F, &uint16_value);        // Registerdan istenilen değeri oku
        delay(time_after_communication);                                            // iki modbus haberleşmesi arası beklenecek min süre
        read_or_write_number = (float)uint16_value;                                 // Okunan değeri basamaklara ayrılıp ekrana yazılması için global değişkene at
        number_entry_opening_page(read_or_write_number, positive, decimal_number);  // Okunan değeri bulunduran değişkeni ekrana basamak basamak yaz
        digit = 7;                                                                  // imleçin en sağdaki basamakta kalması için

        tft.setFreeFont(FSSB12);
        if (language == English) {
          tft.drawString(english[34], 75, 28);
          tft.setFreeFont(FSS12);
          tft.drawString(english[69], 80, 190);  // Range
        } else if (language == Turkish) {
          tft.drawString(turkish[34], 76, 28);
          tft.setFreeFont(FSS12);
          tft.drawString(turkish[69], 90, 190);
        }
        tft.drawString("=  0 - 4", 160, 190);
      }

      // Buton kontrolü
      if (button_state == press_esc) {
        button_state = idle;

        opening_page = true;
        screen_switch = flow_parameters;
      } else if (button_state == press_enter) {
        button_state = idle;

        number_entry();  // basamaklardaki rakamları read_or_write_number global değişkenine yazar
        uint16_value = (uint16_t)read_or_write_number;

        if (uint16_value >= 0 && uint16_value <= 5) {  // Girilen sayı aralıktaysa registera yaz range yazısını 1 sn yeşil yap
          modbus_master.read_or_write(1, WRITE_MULTI, 0x021F, &uint16_value);
          delay(time_after_communication);  // iki modbus haberleşmesi arası beklenecek min süre

          tft.fillRect(80, 163, 150, 18, TFT_WHITE);  // Arka plan temizle
          tft.setTextColor(TFT_DARKGREEN, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[2], 135, 162);  // done !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 80, 190);  // Range
            tft.drawString("=  0 - 4", 160, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[2], 112, 162);  // onaylandi !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 90, 190);  // Aralik
            tft.drawString("=  0 - 4", 160, 190);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        } else {  // Girilen sayı aralıkta değilse registera yazma range yazısını kırmızı yap
          tft.setTextColor(TFT_RED, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[73], 105, 162);  // out of range
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 80, 190);  // Range
            tft.drawString("=  0 - 4", 160, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[73], 95, 162);  // araligin disinda
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 90, 190);  // Aralik
            tft.drawString("=  0 - 4", 160, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        }


      } else if (button_state == press_up) {
        button_state = idle;

        if (number[7] >= 4) number[7] = -1;
        increase_digit_number();
      } else if (button_state == press_down) {
        button_state = idle;
      }
      cursor_movement();  // Basamak altı kısa kırmızı çizginin hareklerini gerçekleştir

      break;


    case flow_cut_off:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x0236, &read_or_write_number);
        delay(time_after_communication);                                                // iki modbus haberleşmesi arası beklenecek min süre
        number_entry_opening_page(read_or_write_number, positive, non_decimal_number);  // Okunan değeri bulunduran değişkeni ekrana basamak basamak yaz
        // digit = 4;
        tft.setFreeFont(FSSB12);
        if (language == English) {
          tft.drawString(english[36], 85, 28);  // Flow Cut-Off
          tft.setFreeFont(FSS12);
          tft.drawString(english[69], 60, 190);  // Range
        } else if (language == Turkish) {
          tft.drawString(turkish[36], 60, 28);  // Akis Kesim Siniri
          tft.setFreeFont(FSS12);
          tft.drawString(turkish[69], 69, 190);  // Aralik
        }
        tft.drawString("= 0.0 - 20.0", 136, 190);
      }

      // Buton kontrolü
      if (button_state == press_esc) {
        button_state = idle;

        opening_page = true;
        screen_switch = flow_parameters;
      } else if (button_state == press_enter) {
        button_state = idle;

        number_entry();  // basamaklardaki rakamları read_or_write_number global değişkenine yazar

        if (read_or_write_number >= 0.0 && read_or_write_number <= 20.0) {  // Girilen sayı aralıktaysa registera yaz range yazısını 1 sn yeşil yap
          modbus_master.read_or_write(1, WRITE_MULTI, 0x0236, &read_or_write_number);
          delay(time_after_communication);            // iki modbus haberleşmesi arası beklenecek min süre
          tft.fillRect(80, 163, 150, 18, TFT_WHITE);  // Arka plan temizle
          tft.setTextColor(TFT_DARKGREEN, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[2], 135, 162);  // done !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 60, 190);  // Range
            tft.drawString("= 0.0 - 20.0", 136, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[2], 112, 162);  // onaylandi !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 69, 190);  // Aralik
            tft.drawString("= 0.0 - 20.0", 136, 190);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        } else {  // Girilen sayı aralıkta değilse registera yazma range yazısını kırmızı yap

          tft.setTextColor(TFT_RED, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[73], 105, 162);  // out of range
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 60, 190);  // Range
            tft.drawString("= 0.0 - 20.0", 136, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[73], 95, 162);  // araligin disinda
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 69, 190);  // Aralik
            tft.drawString("= 0.0 - 20.0", 136, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        }


      } else if (button_state == press_up) {
        button_state = idle;

        increase_digit_number();
      } else if (button_state == press_down) {
        button_state = idle;

        digit++;
        // if (digit > 7) digit = 4;
      }
      cursor_movement();  // Basamak altı kısa kırmızı çizginin hareklerini gerçekleştir
      break;

    case calculation_method:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        screen_switch = flow_parameters;

        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        uint16_value = cursor - liquid_volume;  // anakarta register hazırlandı yazmak için

        modbus_master.read_or_write(1, WRITE_MULTI, 0x0201, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        if (uint16_value >= 0 && uint16_value <= 5) tick_location = uint16_value + 1;
        else if (uint16_value >= 6 && uint16_value <= 7) tick_location = uint16_value - 5;

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        previous_cursor = 100;
        modbus_master.read_or_write(1, READ_HOLDING, 0x0201, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre
        if (uint16_value >= 6 && uint16_value <= 7) cursor = steam_sat_temp_comp;
        else cursor = liquid_volume;
      }

      if (cursor < liquid_volume) {
        opening_page = true;
        first_text = true;
        cursor = steam_sat_pres_comp;
      } else if (cursor > steam_sat_pres_comp) {
        opening_page = true;
        first_text = true;
        cursor = liquid_volume;
      } else if (cursor == steam_pres_temp_comp && previous_cursor == steam_sat_temp_comp) {
        opening_page = true;
        first_text = true;
      } else if (cursor == steam_sat_temp_comp && previous_cursor == steam_pres_temp_comp) {
        opening_page = true;
        first_text = true;
      }

      if (cursor >= liquid_volume && cursor <= steam_pres_temp_comp) {

        if (opening_page == true) {
          tick_location = uint16_value + 1;
        }

        bar_select(basic_settings_icon, 37, 70, middle_aligned, true, 179, 180, 181, 182, 183, 184, liquid_volume, steam_pres_temp_comp);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("1/2", 267, 13);
        }

      } else if (cursor >= steam_sat_temp_comp && cursor <= steam_sat_pres_comp) {
        if (opening_page == true) {
          tick_location = uint16_value - 5;
        }
        bar_select(basic_settings_icon, 37, 70, middle_aligned, true, 185, 186, steam_sat_temp_comp, steam_sat_pres_comp);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("2/2", 271, 13);
        }
      }

      break;

    case sensor_size:
    case _sensor_size:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;

        if (previous_screen_switch == quick_setup) {
          screen_switch = quick_setup;
          previous_screen_switch = 0;
        } else {
          screen_switch = basic_settings;
        }

        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        if (cursor == insertion_type) {
          // opening_page = true;
          // screen_switch = insertion_type;

          break;

        } else {

          if (uint16_value <= 19) uint16_value = cursor - DN15;             // anakarta register hazırlandı yazmak için
          else if (uint16_value >= 256) uint16_value = cursor - DN15 + 256;  // anakarta register hazırlandı yazmak için

          modbus_master.read_or_write(1, WRITE_MULTI, 0x0202, &uint16_value);
          delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

          // sıvı için
          if (uint16_value >= 0 && uint16_value <= 5) tick_location = cursor - DN15 + 1;
          else if (uint16_value >= 6 && uint16_value <= 11) tick_location = cursor - DN15 - 5;
          else if (uint16_value >= 12 && uint16_value <= 17) tick_location = cursor - DN15 - 11;
          else if (uint16_value == 18) tick_location = 1;

          // gaz için
          if (uint16_value >= 256 && uint16_value <= 261) tick_location = cursor - DN15 + 1;
          else if (uint16_value >= 262 && uint16_value <= 267) tick_location = cursor - DN15 - 5;
          else if (uint16_value >= 268 && uint16_value <= 273) tick_location = cursor - DN15 - 11;
          else if (uint16_value == 274) tick_location = 1;
        }

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {
        previous_cursor = 100;
        modbus_master.read_or_write(1, READ_HOLDING, 0x0202, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        if (uint16_value <= 19) cursor = DN15 + uint16_value;
        else if (uint16_value >= 256) cursor = DN15 + uint16_value - 256;
      }

      if (cursor < DN15) {
        opening_page = true;
        first_text = true;
        cursor = DN600;
      } else if (cursor > insertion_type) {
        opening_page = true;
        first_text = true;
        cursor = DN15;
      } else if ((cursor == DN65 && previous_cursor == DN50) || (cursor == DN50 && previous_cursor == DN65)) {
        opening_page = true;
        first_text = true;
      } else if ((cursor == DN200 && previous_cursor == DN250) || (cursor == DN250 && previous_cursor == DN200)) {
        opening_page = true;
        first_text = true;
      } else if ((cursor == DN500 && previous_cursor == DN600) || (cursor == DN600 && previous_cursor == DN500)) {
        opening_page = true;
        first_text = true;
      }


      if (cursor >= DN15 && cursor <= DN50) {

        if (opening_page == true) {
          if (uint16_value <= 19) tick_location = uint16_value + 1;
          else if (uint16_value >= 256) tick_location = uint16_value - 256 + 1;
        }

        bar_select(basic_settings_icon, 17, 138, middle_aligned, true, 160, 161, 162, 163, 164, 165, DN15, DN50);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("1/4", 250, 13);
        }

      } else if (cursor >= DN65 && cursor <= DN200) {
        if (opening_page == true) {
          if (uint16_value <= 19) tick_location = uint16_value - 5;
          else if (uint16_value >= 256) tick_location = uint16_value - 256 - 5;
        }

        bar_select(basic_settings_icon, 17, 138, middle_aligned, true, 166, 167, 168, 169, 170, 171, DN65, DN200);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("2/4", 250, 13);
        }

      } else if (cursor >= DN250 && cursor <= DN500) {
        if (opening_page == true) {
          if (uint16_value <= 19) tick_location = uint16_value - 11;
          else if (uint16_value >= 256) tick_location = uint16_value - 256 - 11;
        }

        bar_select(basic_settings_icon, 17, 138, middle_aligned, true, 172, 173, 174, 175, 176, 177, DN250, DN500);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("3/4", 250, 13);
        }
      } else if (cursor > DN500) {
        if (opening_page == true) {
          if (uint16_value <= 19) tick_location = uint16_value - 17;
          else if (uint16_value >= 256) tick_location = uint16_value - 256 - 17;
        }

        bar_select(basic_settings_icon, 17, 120, middle_aligned, true, 178, 268, DN600, insertion_type);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("4/4", 250, 13);
        }
      }

      break;

    case insertion_type:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x020C, &read_or_write_number);
        delay(time_after_communication);                                                // iki modbus haberleşmesi arası beklenecek min süre
        number_entry_opening_page(read_or_write_number, positive, non_decimal_number);  // Okunan değeri bulunduran değişkeni ekrana basamak basamak yaz

        tft.setFreeFont(FSSB12);
        if (language == English) {
          tft.drawString(english[17], 90, 28);  // Sensor Size
          tft.setFreeFont(FSS12);
          tft.drawString(english[69], 33, 190);  // Range
        } else if (language == Turkish) {
          tft.drawString(turkish[17], 82, 28);  // Boru Capı
          tft.setFreeFont(FSS12);
          tft.drawString(turkish[69], 42, 190);  // Aralik
        }
        tft.drawString("= 0.0001 - 99999", 109, 190);
      }

      // Buton kontrolü
      if (button_state == press_esc) {
        button_state = idle;

        opening_page = true;
        first_text = true;

        screen_switch = sensor_size;

      } else if (button_state == press_enter) {
        button_state = idle;

        number_entry();  // basamaklardaki rakamları read_or_write_number global değişkenine yazar

        if (read_or_write_number >= 0.000095 && read_or_write_number <= 99999) {  // Girilen sayı aralıktaysa registera yaz range yazısını 1 sn yeşil yap
          // modbus_master.read_or_write(1, WRITE_MULTI, 0x020C, &read_or_write_number);
          // delay(time_after_communication);            // iki modbus haberleşmesi arası beklenecek min süre
          tft.fillRect(80, 163, 150, 18, TFT_WHITE);  // Arka plan temizle
          tft.setTextColor(TFT_DARKGREEN, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[2], 135, 162);  // done !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 33, 190);  // Range
            tft.drawString("= 0.0001 - 99999", 109, 190);
          } else if (language == Turkish) {
            tft.drawString(turkish[2], 112, 162);  // onaylandi !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 42, 190);  // Aralik
            tft.drawString("= 0.0001 - 99999", 109, 190);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);  // done !
        } else {                                                    // Girilen sayı aralıkta değilse registera yazma range yazısını kırmızı yap

          tft.setTextColor(TFT_RED, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[73], 105, 162);  // out of range
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 33, 190);  // Range
            tft.drawString("= 0.0001 - 99999", 109, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[73], 95, 162);  // araligin disinda
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 42, 190);  // Aralik
            tft.drawString("= 0.0001 - 99999", 109, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);  // done !
        }


      } else if (button_state == press_up) {
        button_state = idle;

        increase_digit_number();
      } else if (button_state == press_down) {
        button_state = idle;

        digit++;
      }
      cursor_movement();  // Basamak altı kısa kırmızı çizginin hareklerini gerçekleştir


      break;

    case quick_setup:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = basic_settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        opening_page = true;
        first_text = true;
        previous_screen_switch = quick_setup;
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(basic_settings_icon, 154, 75, left_aligned, false, 269, 17, 33, 108, 148, _fluid_type, _pulse_factor);

      break;

    case advanced_settings:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = settings;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }


      if (cursor < preset) {
        opening_page = true;
        first_text = true;
        cursor = change_password;
      } else if (cursor > change_password) {
        opening_page = true;
        first_text = true;
        cursor = preset;
      } else if (cursor == total_reset && previous_cursor == channel_setting) {
        opening_page = true;
        first_text = true;
      } else if (cursor == channel_setting && previous_cursor == total_reset) {
        opening_page = true;
        first_text = true;
      }

      if (cursor >= preset && cursor <= total_reset) {

        bar_select(advanced_setting_icon, 5, 75, left_aligned, false, 223, 114, 228, 232, 108, 21, preset, total_reset);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("1/2", 267, 13);
        }

      } else if (cursor >= channel_setting && cursor <= change_password) {

        bar_select(advanced_setting_icon, 5, 75, left_aligned, false, 248, 234, 22, 20, channel_setting, change_password);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("2/2", 267, 13);
        }
      }


      break;

    case preset:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = advanced_settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(advanced_setting_icon, 223, 75, left_aligned, false, 224, 225, gas_pressure, gas_temperature);

      break;

    case density:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = advanced_settings;  // ayarlar sayfasına git
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(advanced_setting_icon, 114, 75, left_aligned, false, 226, 227, gas_density, liquid_density);

      break;

    case gas_pressure:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x0216, &read_or_write_number);
        delay(time_after_communication);                                                    // iki modbus haberleşmesi arası beklenecek min süre
        number_entry_opening_page(read_or_write_number, non_positive, non_decimal_number);  // Okunan değeri bulunduran değişkeni ekrana basamak basamak yaz

        tft.setFreeFont(FSS12);
        if (language == English) {
          tft.drawString(english[224], 48, 28);   // gas temperature
          tft.drawString(english[223], 202, 28);  // density
          tft.setFreeFont(FSS12);
          tft.drawString(english[69], 27, 190);  // Range
        } else if (language == Turkish) {
          tft.drawString(turkish[224], 55, 28);
          tft.drawString(turkish[223], 185, 28);
          tft.setFreeFont(FSS12);
          tft.drawString(turkish[69], 27, 190);  // Aralik
        }
        tft.drawString("= 999999 - 100", 102, 190);
        tft.drawString("Kpa", 243, 117);
      }

      // Buton kontrolü
      if (button_state == press_esc) {
        button_state = idle;

        opening_page = true;
        screen_switch = preset;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        number_entry();  // basamaklardaki rakamları read_or_write_number global değişkenine yazar

        if (read_or_write_number >= -100.0 && read_or_write_number <= 999999.0) {  // Girilen sayı aralıktaysa registera yaz range yazısını 1 sn yeşil yap
          modbus_master.read_or_write(1, WRITE_MULTI, 0x0216, &read_or_write_number);
          delay(time_after_communication);            // iki modbus haberleşmesi arası beklenecek min süre
          tft.fillRect(80, 163, 150, 18, TFT_WHITE);  // Arka plan temizle
          tft.setTextColor(TFT_DARKGREEN, TFT_WHITE);
