            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 57, 190);  // Aralik
            tft.drawString("= 99999 - 0", 132, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        }


      } else if (button_state == press_up) {
        button_state = idle;

        increase_digit_number();
      } else if (button_state == press_down) {
        button_state = idle;

        digit++;
      }
      cursor_movement();  // Basamak altı kısa kırmızı çizginin hareklerini gerçekleştir


      break;

    case fine_calibration:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        first_text = true;
        screen_switch = advanced_settings;
        cursor = channel_setting;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        if (cursor == k_factor_calibration) {
          cursor = points_of_calibration;
          first_text = true;
        }
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(advanced_setting_icon, 22, 50, left_aligned, false, 249, 250, 251, k_factor_calibration, sensor_read_calibration);

      break;

    case change_password:

      static bool change_password_key = false;

      if (opening_page == true) {
        opening_page = false;

        tft.fillScreen(TFT_BLACK);

        tft.setTextColor(TFT_ORANGE, TFT_BLACK);
        tft.setFreeFont(FSS18);
        if (language == English) {
          tft.drawString(english[0], 81, 40);  // Password
          tft.setFreeFont(FSS9);
          tft.drawString(english[92], 45, 190);  // Please Enter Valid Password
        } else if (language == Turkish) {
          tft.drawString(turkish[0], 125, 40);  // Sifre
          tft.setFreeFont(FSS9);
          tft.drawString(turkish[92], 65, 190);  // Lutfen Sifre Gecerli Girin
        }

        tft.drawWideLine(270, 95, 50, 95, 3, TFT_SILVER, TFT_SILVER);  // çizgi

        tft.pushImage(70, 120, 40, 40, locckk);  // kilit ikonu

        draw_char(0, 115, 121, TFT_BLACK, TFT_WHITE);
        draw_char(0, 148, 121, TFT_WHITE, TFT_BLACK);
        draw_char(0, 181, 121, TFT_WHITE, TFT_BLACK);
        draw_char(0, 214, 121, TFT_WHITE, TFT_BLACK);

        digit = 0;

        memset(number, 0, sizeof(number));
      }

      if (button_state == press_up) {
        button_state = idle;
        if (digit == 0) {
          number[0]++;
          if (number[0] > 9) number[0] = 0;
          draw_char(number[0], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 1) {
          number[1]++;
          if (number[1] > 9) number[1] = 0;
          draw_char(number[1], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 2) {
          number[2]++;
          if (number[2] > 9) number[2] = 0;
          draw_char(number[2], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 3) {
          number[3]++;
          if (number[3] > 9) number[3] = 0;
          draw_char(number[3], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        }


      } else if (button_state == press_down) {
        button_state = idle;
        digit++;
        if (digit > 3) digit = 0;

        if (digit == 0) {
          draw_char(number[3], 115 + 3 * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[0], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 1) {
          draw_char(number[0], 115 + (digit - 1) * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[1], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 2) {
          draw_char(number[1], 115 + (digit - 1) * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[2], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        } else if (digit == 3) {
          draw_char(number[2], 115 + (digit - 1) * 33, 121, TFT_WHITE, TFT_BLACK);
          draw_char(number[3], 115 + digit * 33, 121, TFT_BLACK, TFT_WHITE);
        }



      } else if (button_state == press_enter) {
        button_state = idle;

        uint16_t password = number[0] * 1000 + number[1] * 100 + number[2] * 10 + number[3];  // girilen şifreyi password değişkenine ata

        if (change_password_key == false) {
          if (main_password == password || master_password == password) {

            change_password_key = true;

            draw_char(0, 115, 121, TFT_BLACK, TFT_WHITE);
            draw_char(0, 148, 121, TFT_WHITE, TFT_BLACK);
            draw_char(0, 181, 121, TFT_WHITE, TFT_BLACK);
            draw_char(0, 214, 121, TFT_WHITE, TFT_BLACK);
            digit = 0;

            memset(number, 0, sizeof(number));
            tft.fillRect(20, 190, 300, 20, TFT_BLACK);

            tft.setTextColor(TFT_DARKGREEN, TFT_BLACK);
            tft.setFreeFont(FSS9);
            if (language == English) {
              tft.drawString(english[2], 145, 190);  // done
              delay(1500);
              tft.setTextColor(TFT_ORANGE, TFT_BLACK);
              tft.drawString(english[93], 50, 190);  // please enter new password
            } else if (language == Turkish) {
              tft.drawString(turkish[2], 120, 190);  // onaylandı
              delay(1500);
              tft.setTextColor(TFT_ORANGE, TFT_BLACK);
              tft.drawString(turkish[93], 75, 190);  // lütfen yeni şifreyi girin
            }

          } else {

            tft.fillRect(80, 190, 200, 20, TFT_BLACK);
            tft.setTextColor(TFT_RED, TFT_BLACK);
            tft.setFreeFont(FSS9);
            if (language == English) {
              tft.drawString(english[3], 45, 190);  // Wrong Password !  Try Again
              tft.setFreeFont(FSS18);
              tft.drawString(english[0], 81, 40);  // Password
              delay(1500);
              tft.setTextColor(TFT_ORANGE, TFT_BLACK);
              tft.drawString(english[0], 81, 40);  // Password
            } else if (language == Turkish) {
              tft.drawString(turkish[3], 45, 190);  // Şifre yanlış Tekrar deneyin
              tft.setFreeFont(FSS18);
              tft.drawString(turkish[0], 125, 40);  // Sifre
              delay(1500);
              tft.setTextColor(TFT_ORANGE, TFT_BLACK);
              tft.drawString(turkish[0], 125, 40);  // Sifre
            }
          }
        } else {
          change_password_key = false;

          EEPROM.writeUShort(main_password_address, password);  // Değiştirilen şifreyi eeproma yazmaya hazırla

          EEPROM.commit();  // kaydet

          main_password = password;

          tft.fillRect(20, 190, 300, 20, TFT_BLACK);
          tft.setTextColor(TFT_DARKGREEN, TFT_BLACK);
          tft.setFreeFont(FSS9);
          if (language == English) {
            tft.drawString(english[94], 50, 190);  // the password was chanced
          } else if (language == Turkish) {
            tft.drawString(turkish[94], 105, 190);  // sifre degistildi
          }
          delay(2000);
          screen_switch = advanced_settings;

          opening_page = true;
        }

      } else if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        change_password_key = false;
        first_text = true;
        cursor = channel_setting;
        screen_switch = advanced_settings;
      }

      break;

    case k_factor_calibration:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = fine_calibration;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }


      if (cursor < points_of_calibration) {
        opening_page = true;
        first_text = true;
        cursor = coefficient_value_5;
      } else if (cursor > coefficient_value_5) {
        opening_page = true;
        first_text = true;
        cursor = points_of_calibration;
      } else if (cursor == frequency_value_3 && previous_cursor == coefficient_value_3) {
        opening_page = true;
        first_text = true;
      } else if (cursor == coefficient_value_3 && previous_cursor == frequency_value_3) {
        opening_page = true;
        first_text = true;
      }

      if (cursor >= points_of_calibration && cursor <= frequency_value_3) {

        bar_select(advanced_setting_icon, 249, 70, left_aligned, false, 235, 236, 237, 238, 239, 240, points_of_calibration, frequency_value_3);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("1/2", 271, 13);
        }

      } else if (cursor >= coefficient_value_3 && cursor <= coefficient_value_5) {

        bar_select(advanced_setting_icon, 249, 70, left_aligned, false, 241, 242, 243, 244, 245, coefficient_value_3, coefficient_value_5);

        if (first_text == true) {
          first_text = false;

          tft.setFreeFont(FSS9);
          tft.setTextColor(TFT_BLACK, TFT_WHITE);
          tft.drawString("2/2", 271, 13);
        }
      }

      break;

    case trims:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = fine_calibration;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(advanced_setting_icon, 250, 80, left_aligned, false, 253, 254, 255, 256, temp_higher_point_for_trims, pres_lower_point_for_trims);

      break;

    case sensor_read_calibration:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = fine_calibration;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;
        opening_page = true;
        screen_switch = cursor;  // kursor nerdeyse o ayara git
        break;
      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      bar_select(advanced_setting_icon, 251, 70, left_aligned, false, 253, 254, 255, 256, temp_higher_point_for_sensor, pres_lower_point_for_sensor);


      break;

    case points_of_calibration:

      if (button_state == press_esc) {
        button_state = idle;
        opening_page = true;
        screen_switch = k_factor_calibration;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        if (cursor == no_point) {
          uint16_value = 0;
          tick_location = 1;
        } else if (cursor >= _2_point_calibration && cursor <= _5_point_calibration) {
          uint16_value = tick_location = cursor - _2_point_calibration + 2;
        }

        modbus_master.read_or_write(1, WRITE_MULTI, 0x0221, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

      } else if (button_state == press_up) {
        button_state = idle;
        cursor--;
      } else if (button_state == press_down) {
        button_state = idle;
        cursor++;
      }

      if (opening_page == true) {

        modbus_master.read_or_write(1, READ_HOLDING, 0x0221, &uint16_value);
        delay(time_after_communication);  // iki modbus komutu arası beklencek min süre

        if (uint16_value == 0) tick_location = 1;
        else if (uint16_value >= 2 && uint16_value <= 5) tick_location = uint16_value;
      }

      bar_select(basic_settings_icon, 235, 130, middle_aligned, true, 260, 261, 262, 263, 264, no_point, _5_point_calibration);

      break;

    case frequency_value_1:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x0222, &read_or_write_number);
        delay(time_after_communication);                                                // iki modbus haberleşmesi arası beklenecek min süre
        number_entry_opening_page(read_or_write_number, positive, non_decimal_number);  // Okunan değeri bulunduran değişkeni ekrana basamak basamak yaz

        tft.setFreeFont(FSSB12);
        if (language == English) {
          tft.drawString(english[236], 50, 28);  // Frequency value 1
          tft.setFreeFont(FSS12);
          tft.drawString(english[69], 52, 190);  // Range
        } else if (language == Turkish) {
          tft.drawString(turkish[236], 60, 28);
          tft.setFreeFont(FSS12);
          tft.drawString(turkish[69], 52, 190);  // Aralik
        }
        tft.drawString("= 999999 - 0", 127, 190);
        tft.drawString(" Hz", 236, 117);
      }

      // Buton kontrolü
      if (button_state == press_esc) {
        button_state = idle;
        first_text = true;
        opening_page = true;
        screen_switch = k_factor_calibration;
        break;
      } else if (button_state == press_enter) {
        button_state = idle;

        number_entry();  // basamaklardaki rakamları read_or_write_number global değişkenine yazar

        if (read_or_write_number >= 0 && read_or_write_number <= 999999) {  // Girilen sayı aralıktaysa registera yaz range yazısını 1 sn yeşil yap
          modbus_master.read_or_write(1, WRITE_MULTI, 0x0222, &read_or_write_number);
          delay(time_after_communication);            // iki modbus haberleşmesi arası beklenecek min süre
          tft.fillRect(80, 163, 150, 18, TFT_WHITE);  // Arka plan temizle
          tft.setTextColor(TFT_DARKGREEN, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[2], 135, 162);  // done !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 52, 190);  // Range
            tft.drawString("= 999999 - 0", 127, 190);
          } else if (language == Turkish) {
            tft.drawString(turkish[2], 112, 162);  // onaylandi !
            tft.setTextColor(TFT_GREY, TFT_WHITE);
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 52, 190);  // Aralik
            tft.drawString("= 999999 - 0", 127, 190);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        } else {  // Girilen sayı aralıkta değilse registera yazma range yazısını kırmızı yap

          tft.setTextColor(TFT_RED, TFT_WHITE);
          tft.setFreeFont(FSSB9);
          if (language == English) {
            tft.drawString(english[73], 105, 162);  // out of range
            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 52, 190);  // Range
            tft.drawString("= 999999 - 0", 127, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[73], 95, 162);  // araligin disinda
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 52, 190);  // Aralik
            tft.drawString("= 999999 - 0", 127, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        }


      } else if (button_state == press_up) {
        button_state = idle;

        increase_digit_number();
      } else if (button_state == press_down) {
        button_state = idle;

        digit++;
      }
      cursor_movement();  // Basamak altı kısa kırmızı çizginin hareklerini gerçekleştir

      break;

    case coefficient_value_1:

      // Case döngüsüne ilk girdiğinde bir kez yapılacaklar
      if (opening_page == true) {
        opening_page = false;

        modbus_master.read_or_write(1, READ_HOLDING, 0x022C, &read_or_write_number);
