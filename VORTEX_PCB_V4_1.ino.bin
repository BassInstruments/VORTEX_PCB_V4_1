            tft.setFreeFont(FSS12);
            tft.drawString(english[69], 52, 190);  // Range
            tft.drawString("= 1.999 - 0.5 ", 127, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          } else if (language == Turkish) {
            tft.drawString(turkish[73], 95, 162);  // araligin disinda
            tft.setFreeFont(FSS12);
            tft.drawString(turkish[69], 52, 190);  // Aralik
            tft.drawString("= 1.999 - 0.5 ", 127, 190);
            tft.setTextColor(TFT_GREY, TFT_WHITE);
          }
          delay(1000);
          tft.drawString("                            ", 75, 162);
        }


